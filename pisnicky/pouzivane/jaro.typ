#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Jaro],
  author: [Fešáci],
  capo: 2,
  doc,
)

#verse[
  #c[Ami]My čekali #c[C]jaro, a #c[G]zatím přišel #c[Ami]mráz,\
  tak strašlivou #c[C]zimu ne#c[G]zažil nikdo z #c[Ami]nás,\
  z těžkých černých #c[C]mraků se #c[G]stále sypal #c[Ami]sníh\
  a vánice #c[C]sílí v po#c[G]ryvech ledo#c[Ami]vých.\
  Z #c[C]chýší dřevo mizí a #c[G]mouky ubývá,\
  #c[Dmi]do sýpek se raději už #c[G]nikdo nedívá,\
  #c[C]zvěř z okolních lesů nám #c[G]stála u dveří\
  #c[Dmi]a hladoví ptáci při#c[G]létli za zvěří, a stále #c[Ami]blíž.
]

#verse[
  Jednoho dne večer, to už jsem skoro spal,\
  když vystrašenej soused na okno zaklepal:\
  "Můj syn doma leží, v horečkách vyvádí,\
  do města bych zajel, doktor snad poradí."\
  Půjčil jsem mu koně, a když sedlo zapínal,\
  ještě, než se rozjel, tak jsem ho varoval:\
  "Nejezdi tou zkratkou, je tam příkrej sráz\
  a v týhletý bouři si tam snadno zlámeš vaz, tak neriskuj!"
]

#verse[
  Na to smutný ráno dnes nerad vzpomínám,\
  na tu strašnou chvíli, když kůň se vrátil sám,\
  trvalo to dlouho, než se vítr utišil,\
  do ledových plání si každý pospíšil.\
  Jeli jsme tou zkratkou až k místu, které znám,\
  kterým bych v té bouři nejel nikdy sám,\
  v tom ho někdo spatřil, jak tam leží pod srázem,\
  krev nám tuhla v žilách nad tím obrazem, já klobouk sňal.
]

#verse[
  #c[Ami]Někdy ten, #c[C]kdo spěchá, se #c[G]domů nevra#c[Ami]cí...
]
