#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Černej pasažér],
  author: [Traband],
  doc,
)


#verse[
  Mám #c[Dmi]kufr plnej přebytečnejch #c[A]krámů\
  a #c[A]mapu zabalenou do plát#c[Dmi]na.\
  Můj #c[Dmi]vlak však jede na opačnou #c[A]stranu\
  a #c[A]moje jízdenka je dávno neplat#c[Dmi]ná.
]

#bridge[
  #rep[
    #c[Dmi]--, #s[C5]--, #s[F]--, - - - - - --, - - - - - #c[Dmi]--, --, --.
  ]
]

#verse[
  Někde ve vzpomínkách stojí dům,\
  ještě vidím, jak se kouří z komína.\
  V tom domě pro mě prostřený stůl,\
  tam já a moje rodina.
]

#verse[
  Moje minulost se na mě šklebí\
  a srdce bolí, když si vzpomenu,\
  že stromy, který měly dorůst k nebi,\
  tu leží vyvrácený z kořenů.
]

#bridge[
  #rep[
    #c[Dmi]Ná, #s[C5]ná, #c[F]ná, na na na na na ná, na na na na na #c[Dmi]ná, ná, ná.
  ]
]

#chorus[
  Jsem černej #c[B]pasažér, #c[C]nemám cíl #c[F]ani směr,\
  vezu se #c[B]načerno #c[C]životem a #c[F]nevím.\
  Jsem černej #c[B]pasažér, #c[C]nemám cíl #c[F]ani směr,\
  vezu se #c[B]odnikud #c[C]nikam a #c[A]nevím, kde skončím.
]

#verse[
  Mám to všechno na barevný fotce,\
  někdy z minulýho století.\
  Tu jedinou a pocit bezdomovce\
  si sebou nesu stále v paměti.
]

#bridge[
  #rep[
    #c[Dmi]Á, #s[C5]á, #s[F]á, a a a a a á, a a a a a #c[Dmi]á, á, á.
  ]
]

#chorus[
  Jsem černej pasažér...
]
