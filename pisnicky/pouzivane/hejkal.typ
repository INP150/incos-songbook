#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Hejkal],
  author: [Wabi Daněk],
  doc,
)

#verse[
  #c[Ami]Divnej jekot po lesích se prohání,\
  až v #c[Dmi]žilách tuhne #c[Ami]krev a zuby #c[F]cvakaj' SO#c[E]S,\
  #c[Ami]utichá až u potoka pod strání,\
  jó, #c[Dmi]takovýhle #c[Ami]řvaní by #c[E]nesnes' ani #c[Ami]pes.\
  #c[Dmi]Žhavý rudý #c[Ami]oči a #c[Dmi]drápy krva#c[Ami]vý,\
  #c[F]kosti chřestěj' v rytmu kasta#c[E]nět,\
  a #c[Dmi]strašidelný #c[Ami]vytí a #c[Dmi]skřeky chrapla#c[Ami]vý,\
  tak #c[F]to je hejkal, na to vemte #c[E]jed.#c[Ami]
]

#chorus[
  U nás #c[C]hej (HEJ), #c[F]hej (HEJ), #c[C]hejkal straší v lese,\
  jen #c[C]ten, kdo něco snese, tam #c[D7]může v noci #c[G]jít,\
  jeho #c[C]hej (HEJ), #c[F]hej (HEJ), #c[C]hejkání se nese,\
  kaž#c[F]dej se strachy #c[C]třese, k ohni #c[F]nesesedne#c[C]me se,\
  ne#c[F]boť za boudou v #c[C]lese zase #c[G7]hejkal začal #c[C]výt.
]

#verse[
  Kdo z vás tady na hejkaly nevěří,\
  ten může u nás přespat, až se zastaví,\
  nevystrčí špičku nosu ze dveří\
  a bude jásat, že se dožil rána ve zdraví.\
  Jenom kalný oči a rysy ztrhané,\
  kalhoty si bude muset prát,\
  a děs a hrůza v hlase, jó, to mu zůstane,\
  až koktavě bude povídat, že
]

#chorus[
  U nás hej (HEJ)...
]
