#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Mezi horami],
  author: [Čechomor],
  doc,
)

#verse[
  #rep[#c[Ami]Mezi #c[G]hora#c[Ami]mi, lipka #c[G]zele#c[Ami]ná,]\
  #rep[#c[C]zabili Janka, #c[G]Janíčka, #c[Ami]Janka, miesto #c[G]jele#c[Ami]ňa.]
]

#verse[
  Keď ho zabili, zamordovali,\
  na jeho hrobě, na jeho hrobě, kříž postavili.
]

#verse[
  Ej, křížu, křížu, ukřižovaný,\
  zde leží Janík, Janíček, Janík, zamordovaný.
]

#verse[
  Tu šla Anička, plakat Janíčka,\
  hned na hrob padla, a viac nevstala, dobrá Anička.
]

#verse[
  \= 1.
]

