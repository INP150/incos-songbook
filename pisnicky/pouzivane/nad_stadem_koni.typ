#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Nad stádem koní],
  author: [Buty],
  cols: 2,
  doc,
)

#verse[
  #c[D]Nad stádem #c[A]koní,#c[Emi]\
  podkovy #c[G]zvoní, zvoní,#c[D]\
  černý vůz vlečou,\
  a slzy tečou a já volám:\
  Tak neplač můj kamaráde\
  náhoda je blbec když krade.
]

#verse[
  Je #c[D]tuhý jak #c[A]veka,\
  a řeka ho #c[Emi]splaví,\
  máme ho #c[G]rádi.\
  No tak #c[C]co, tak #c[G]co, tak #c[A]co.
]

#verse[
  Vždycky si přál, až bude popel,\
  i s kytarou, hou,\
  Vodou ať plavou, jen žádný hotel,\
  s křížkem nad hlavou.
]

#verse[
  Až najdeš místo, kde je ten pramen,\
  a kámen co praská.\
  Budeš mít jisto, patří sem popel,\
  a každá láska.\
  No tak co, tak co, tak co.
]

#verse[
  Nad stádem koní,\
  podkovy zvoní, zvoní,\
  černý vůz vlečou,\
  a slzy tečou a já šeptám:
]

#verse[
  Vysyp ten popel, kamaráde,\
  do bílé vody, vody.\
  Vyhasnul kotel a náhoda\
  je štěstí od podkovy.
]

