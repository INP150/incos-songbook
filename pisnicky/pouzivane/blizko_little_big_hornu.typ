  mo#c[Ami]drý kabáty jezdců, stíny #c[Dmi]dlouhejch karabin,\
  a #c[Ami]z indiánskejch signálů po nebi letí #c[A]dým.
]

#chorus[
  #c[A]Říkal to Jim Bridger: já měl jsem v noci #c[E7]sen,\
  pod #c[E7]sedmou kavalerií jak krví rudne #c[A]zem,\
  kmen #c[A]Siouxů je statečný a dobře svůj kraj #c[D]zná,\
  proč #c[E7]Custer neposlouchá ta #c[A]slova varov#c[Ami]ná?
]

#verse[
  Tam #ca[Ami]blízko Little Big Hornu šedivou prérií\
  táh#ca[Ami]ne generál Custer s sedmou #ca[Dmi]kavalerií,\
  mar#ca[Ami]ně mu stopař Bridger radí: #ca[Dmi]zpátky povel dej,\
  je#ca[Ami]dinou možnost ještě máš, život si zacho#ca[A]vej.
]

#chorus[
  Říkal to Jim Bridger…
]

#verse[
  Tam #ca[Ami]blízko Little Big Hornu se vznáší smrti stín,\
