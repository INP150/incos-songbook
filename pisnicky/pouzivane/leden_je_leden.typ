#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Leden je leden],
  author: [Radůza],
  url: "https://www.youtube.com/watch?v=lxcqhZ3GtQw",
  doc,
)

#verse[
  #c[Ami]Leden, je #c[C]leden a #c[D]vítr střechy holí, \
  cizí stopy ve sněhu na terase, \
  ještě jeden rum do koly hodím, \
  nevolej, nechoď, nepiš už je to pasé.#c[F] Jé jé jé jé \
]

#chorus[
  #c[C]A tak stojí #c[F]na konečný, #c[Ami]tramvaj číslo #c[G]pět, \
  #c[Ami]na ty tvoje #c[G]řeči věčný #c[C]radši #c[G]nemyslet. \
  Taková jsem byla hezká, co jsi z toho měl, \
  když na to tak myslím dneska, ani nevím, \
  proč jsi mě tak chtěl. #c[E]Jó jó jó \
]

#verse[
  #c[Ami]Večer, #c[Emi]je večer a sníh mi za krk padá. \
  Ještě čekám, ještě lístek hledám. \
  Leden, je leden \
]

#chorus[
  A tak stojí na konečný...
]

#verse[
  Večer, je večer a sníh mi za krk padá. \
  Ještě čekám, ještě límec zvedám. \
  Leden, je leden a chodníky jsou bílý, \
  tak se flákám městem sem a tam. \
  Ještě jeden citrón hoď si do tequilly, \
  před výkladní skříní zase sám. \
]
