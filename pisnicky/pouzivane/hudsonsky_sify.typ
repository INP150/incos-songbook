#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Hudsonský šífy],
  author: [Wabi Daněk],
  line_spacing: 0.5em,
  doc,
)

#verse[
  Ten, kdo #c[Ami]nezná hukot vody lopat#c[C]kama vířený,\
  jako #c[G]já, jó jako #c[Ami]já,\
  kdo Hud#c[Ami]sonský slapy nezná sírou #c[G]pekla sířený,\
  ať se #c[Ami]na Hudsonský #c[G]šífy najmout #c[Ami]dá, #s[G]jo ho #c[Ami]ho.
]

#verse[
  Ten, kdo nepřekládal uhlí, šíf když na mělčinu vjel,\
  málo zná, málo zná,\
  ten, kdo neměl tělo ztuhlý, až se nočním chladem chvěl,\
  ať se na Hudsonský šífy najmout dá, jo ho ho.
]

#chorus[
  Tak #c[F]ahoj, páru tam #c[Ami]hoď, ať #c[G]do pekla se dříve dohra#c[Ami]bem,\
  #c[G]jo ho #c[Ami]ho, #s[G]jo ho #c[Ami]ho.
]

#verse[
  Ten, kdo nezná noční zpěvy zarostenejch lodníků,\
  jako já, jó jako já,\
  ten, kdo cejtí se bejt chlapem, umí dělat rotyku,\
  ať se na Hudsonský šífy najmout dá, jo ho ho.
]

#verse[
  Ten, kdo má na bradě mlíko, kdo se rumem neopil,\
  málo zná, jó málo zná,\
  kdo necejtil hrůzu z vody, kde se málem utopil,\
  ať se na Hudsonský šífy najmout dá, jo ho ho.
]

#chorus[
  Ahoj, páru tam hoď...
]

#verse[
  Kdo má roztrhaný boty, kdo má pořád jenom hlad,\
  jako já, jó jako já,\
  kdo chce celý noci čuchat pekelnýho vohně smrad,\
  ať se na Hudsonský šífy najmout dá, jo ho ho.
]

#verse[
  Kdo chce zhebnout třeba zejtra, komu je to všechno fuk,\
  kdo je sám, jó jako já,\
  kdo má srdce v správným místě, kdo je prostě príma kluk,\
  ať se na Hudsonský šífy najmout dá, jo ho ho.
]

#chorus[
  Ahoj, páru tam hoď, ať do pekla se dříve dohrabem,\
  jo ho ho, jo ho ho.\
  jo ho ho, jo ho ho.
]

