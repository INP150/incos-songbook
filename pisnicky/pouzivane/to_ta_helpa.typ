#show: doc => song(
  title: [To tá Heľpa],
  author: [Lidová],
  doc,
)

#verse[
  #c[Ami]To ta #c[D]Heľpa #c[Ami]to ta #s[D]Heľpa
  #c[Ami]to je #s[E]pekné #c[Ami]mesto\
  #c[Ami]a v tej #c[D]Heľpe #c[Ami]a v tej #c[D]Heľpe
  #c[Ami]švárnych #c[E]chlapcov #c[Ami]je sto.
]


#chorus[
  #rep[#c[F]Koho je sto #c[C]toho je sto
    #c[G]nie po mojej #c[C]vô#c[E]li,\
    #c[Ami]len za #c[D]jedným #c[Ami]len za #c[D]jedným
    #c[Ami]srdieč#c[E]ko ma #c[Ami]bolí.
  ]
]
#verse[
  Za Janíčkom za Palíčkom krok by nespravila,\
  za Ďuríčkom za Mišíčkom Dunaj preskočila.
]
#chorus[
  #rep[
    Dunaj Dunaj Dunaj Dunaj aj to širé pole,\
    ľen za jedným ľen za jedným počešenie moje.
  ]
]

