#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Válka růží],
  author: [Spirituál kvintet],
  doc,
)

#verse[
  #c[Dmi]Rozplynul se #c[G]hustý dým, #c[Dmi]derry down, hej, #c[A]down-a-down,\
  nad #c[Dmi]ztichlým polem #c[G]válečným, derry #c[Dmi]down,#c[A]\
  jen #c[F]ticho stojí #c[C]kolko#c[A]lem a #c[Dmi]vítěz #c[Dmi/C]plení #s[B]vlastní #c[A]zem.\
  Je válka #c[Dmi]růží, #s[Gmi]derry, derry, #c[A]derry down-a-#c[Dmi]down.
]
#verse[
  Nečekej soucit od rváče, derry down, hej, down-a-down,\
  kdo zabíjí ten nepláče, derry down,\
  na těle mrtvé krajiny se mečem píšou dějiny,\
  je válka růží, down, derry, derry, derry down, a-down.
]
#verse[
  Dva erby, dvojí korouhev, derry down, hej, down-a-down,\
  dva rody živí jeden hněv, derry down,\
  kdo změří, kam se nahnul trůn, zda k Yorkům nebo k\
  Lancastrům,\
  je válka růží, down, derry, derry, derry down, a-down.
]
#verse[
  Dva erby, dvojí korouhev, derry down, hej, down-a-down,\
  však hlína pije jednu krev, derry down,\
  ať ten či druhý přežije, vždy nejvíc ztratí Anglie,\
  je válka růží, down, derry, derry, derry down, a-down.
]

