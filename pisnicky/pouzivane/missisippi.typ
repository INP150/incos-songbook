#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Missisippi],
  author: [Pacifik],
  doc,
)

#verse[
  #c[Ami]Říkali mu Charlie a #c[Dmi]jako malej kluk \
  #c[Ami]kalhoty si #c[G]o plot potr#c[Ami]hal, \
  říkali mu Charlie a #c[Dmi]byl to Toma vnuk, \
  #c[Ami]na plácku rád #c[G]košíkovou #c[Ami]hrál, \
  kř#c[C]ídou kreslil po ohradách pl#c[F]ány dětskejch snů, \
  #c[Dmi]až mu jednou ze tmy řekli: ko#c[E]nec je tvejch dnů, \
  #c[Ami]někdo střelil zezadu a #c[Dmi]vrub do pažby vryl, \
  nikdo #c[Ami]neplakal a #c[G]nikdo nep#c[Ami]rosil. \
]

#chorus[
  Miss#c[C]issippi, Missi#c[Ami]ssippi, #c[F]černý tělo #c[G]nese říční #c[C]proud, \
  Miss#c[C]issippi, Missi#c[Ami]ssippi, #c[F]po ní bude #c[G]jeho duše #c[C]plout. \
]

#verse[
  Říkali mu Charlie a jako každej kluk
  na trubku chtěl ve smokingu hrát,
  v kapse nosil kudlu a knoflíkovej pluk,
  uměl se i policajtům smát,
  odmalička dobře věděl, kam se nesmí jít,
  který věci jinejm patří a co sám může mít,
  že si do něj někdo střelí jak do hejna hus,
  netušil, a neví, řeka zpívá blues.
]

#chorus[
  Mississippi, Mississippi...
]

#verse[
  Chlapec jménem Charlie, a jemu patří blues,
  ve kterým mu táta sbohem dal,
  chlapec jménem Charlie snad došel cesty kus,
  jako slepý na kolejích stál,
  nepochopí jeho oči, jak se může stát,
  jeden že má ležet v blátě, druhej klidně spát,
  jeho blues se naposledy řekou rozletí,
  kdo vyléčí rány, smaže prokletí.
]

#chorus[
  #rep[
    Mississippi, Mississippi...
  ]
]
