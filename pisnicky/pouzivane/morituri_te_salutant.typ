#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style
#show: style

#show: doc => song(
  title: [Morituri te salutant],
  author: [Karel Kryl],
  doc,
)

#verse[
  Cesta je #c[Ami]prach a #c[G]štěrk a #c[Dmi]udusaná #c[Ami]hlína\
  #c[C]a šedé #c[F]šmouhy #c[G7]kreslí do vla#c[C]sů\
  #rep[
    a z hvězdných #c[Dmi]drah má #c[G]šperk, co #c[C]kamením #c[E]sepíná\
    #c[Ami]a pírka #c[G]touhy #c[Emi]z křídel Pega#c[Ami]sů.
  ]
]

#verse[
  Cesta je bič, je zlá jak pouliční dáma,\
  má v ruce štítky, v pase staniol,\
  #rep[
    a z očí chtíč jí plá, když háže do neznáma\
    dvě křehké snítky rudých gladiol.
  ]
]

#chorus[
  Seržante, #c[G]písek je bílý jak paže Daniely,\
  #c[Ami]počkejte chvíli! Mé oči uviděly\
  #c[G]tu strašně dávnou vteřinu zapomnění,\
  #c[Ami]seržante! Mávnou, #c[G7]a budem zasvěceni!\
  #c[Ami]Morituri te salutant, #c[E]morituri te salutant!
]

#verse[
  Tou cestou dál jsem šel, kde na zemi se zmítá\
  a písek víří křídlo holubí,\
  #rep[
    a marš mi hrál zvuk děl, co uklidnění skýtá\
    a zvedá chmýří, které zahubí.
  ]
]

#verse[
  Cesta je tér a prach a udusaná hlína,\
  mosazná včelka od vlkodlaka,\
  #rep[
    rezavý kvér - můj brach a sto let stará špína\
    a děsně velká bílá oblaka.
  ]
]

#chorus[
  Seržante, písek je bílý...
]

