#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Tereza - osamělý město],
  author: [Hoboes],
  url: "https://www.youtube.com/watch?v=ZQGJeEIFdg4",
  doc,
)

#verse[
  Ten #c[C]den, co #c[D]vítr listí z města #c[G]svál \
  můj #c[C]džíp se vracel #c[D]jako by se #c[Em]bál \
  že #c[C]asfaltový #c[D]moře odliv #c[G]má \
  a #c[C]stáj že svýho #c[D]koně nepo#c[E]zná \
]

#chorus[
  Řekni, #c[G]kolik je na světě, kolik je takovejch #c[D]měst \
  řekni, #c[Am]kdo by se vracel, všude je tisíce #c[Em]cest \
  Tenkrát, #c[G]když jsi mi, Terezo, řekla, že ráda mě #c[D]máš \
  tenkrát #c[Am]ptal jsem se, Terezo, kolik mi polibků #c[Em]dáš \
  Napos#c[D]led, napos#c[G]led \
]

#verse[
  Já z dálky viděl město v slunci stát \
  a dál jsem se jen s hrůzou mohl ptát \
  Proč vítr mlátí spoustou okenic, \
  proč jsou v ulici auta jinak nic \
]

#chorus[
  Řekni, kolik je na světě, kolik je takovejch měst...
]

#verse[
  Do prázdnejch beden zotvíranejch aut \
  zaznívá odněkud něžnej tón flaut \
  A v závěji starýho papíru \
  válej se černý klapky z klavíru \
]

#chorus[
  Řekni, kolik je na světě, kolik je takovejch měst...
]

#verse[
  Tak loudám se tím hrozným městem sám \
  a vím že Terezu už nepotkám \
  Jen já tu zůstal s prázdnou ulicí \
  a vosamělý město mlčící \
]

#chorus[
  Řekni, kolik je na světě, kolik je takovejch měst...
]
