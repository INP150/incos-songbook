#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Frankie Dlouhán],
  author: [František Nedvěd],
  doc,
)

#verse[
  Kolik je #c[G]smutného když #c[C]mraky černé #c[G]jdou\
  #c[G]lidem nad hla#c[D]vou, #c[C]smutnou dála#c[G]vou,\
  já slyšel #c[G]příběh, který #c[C]velkou pravdu #c[G]měl,\
  za čas odle#c[D]těl, #c[C]každý zapom#c[G]něl.
]

#chorus[
  Měl kapsu #c[D]prázdnou Frankie Dlouhán,\
  po státech #c[C]toulal se jen #c[G]sám,\
  a že byl #c[C]veselej, tak #c[G]každej měl ho #c[D]rád.\
  Tam ruce #c[C]k dílu mlčky přiloží a #c[G]zase jede #c[Emi]dál,\
  a #c[C]každej kdo s ním #c[D]chvilku byl,\
  tak #c[C]dlouho #c[D]se pak #c[G]smál.
]

#verse[
  Tam kde byl pláč, tam Frankie hezkou píseň měl,\
  slzy neměl rád, chtěl se jenom smát.\
  A když pak ranče večer tiše usínaj,\
  Frankův zpěv jde dál, nocí s písní dál.
]

#chorus[
  Měl kapsu prázdnou Frankie Dlouhán...
]

#verse[
  Tak Frankieho vám jednou našli, přestal žít,\
  jeho srdce spí, tiše klidně spí.\
  Bůh ví jak,za co, tenhle smíšek konec měl,\
  farář píseň pěl, umíráček zněl.
]

#chorus[
  Měl kapsu prázdnou Frankie Dlouhán...
]

