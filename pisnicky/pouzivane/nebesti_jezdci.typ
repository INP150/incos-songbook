#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Nebeští jezdci],
  author: [Waldemar Matuška],
  doc,
)

#verse[
  Po #c[Emi]zasmušilé pustině jel #c[G]starý honec krav, \
  den #c[Emi]temný byl a ševelil větr#c[G]em ve stéblech trav, \
  tu #c[Emi]honec k nebi pohleděl a v hrůze zůstal stát, \
  když z #c[Ami]rozedraných o#c[C]blaků viděl #c[Emi]stádo krav se hnát. \
]

#chorus[
  Jupija #c[G]héj, jupija #c[Emi]hou, to #c[Ami]přízraky #c[C]táhnou #c[Emi]tmou.
]

#verse[
  Ten skot měl nohy z ocele a oči krvavé \
  a na bocích mu plápolaly cejchy řežavé. \
  A oblohou se neslo jeho kopyt dunění \
  a za ním jeli honáci až k smrti znavení. \
]

#chorus[
  Jupija héj...
]

#verse[
  Ti muži byli sinalí a kalný měli zrak \
  a marně stádo stíhali, jak mračno stíhá mrak. \
  A proudy potu máčely jim tvář i košili \
  a starý honec uslyšel jejich jekot kvílivý. \
]

#chorus[
  Jupija héj...
]

#verse[
  Tu jeden honec zavolal a pravil: "Pozor dej", \
  svou duši hříchu uvaruj a ďáblu odpírej, \
  bys nemusel pak po smrti se věčně věků štvát \
  a nekonečnou oblohou to stádo s námi hnát. \
]

#chorus[
  Jupija héj...
]
