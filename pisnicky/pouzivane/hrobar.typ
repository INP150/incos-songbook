#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Hrobař],
  author: [Premiér],
  doc,
)

#verse[
  #c[G]V mládí jsem se učil hrobařem,\
  #c[Emi]jezdit s hlínou, jezdit s trakařem,\
  #c[C]kopat hroby byl můj ide#c[D7]ál.
]

#verse[
  Jezdit s hlínou, jezdit s vozíkem,\
  s černou rakví, s bílým pomníkem,\
  toho bych se nikdy nenadál.
]

#verse[
  Že do módy přijde kremace,\
  černý hrobař bude bez práce,\
  toho bych se nikdy nenadál.
]

#verse[
  Kolem projel vůz milionáře,\
  záblesk světel pad' mi do tváře,\
  marně skřípěj' kola brzdící.
]

#verse[
  Stoupám vzhůru, stoupám ke hvězdám,\
  tam se s černou rakví neshledám,\
  sbohem, bílé město zářící.
]

#verse[
  #c[G]Sbohem, moje #c[Emi]město,\
  #c[C]vzpomínat budu #c[D7]přesto,\
  #c[G]jak jsem poznal #c[Emi]tvůj smích #c[C]a tvůj #c[D7]pláč.
]

#verse[
  Na na na na...
]

