#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Šlapej dál],
  author: [Spirituál kvintet],
  doc,
)

#verse[
  Když svý #c[Ami]černý tělo #c[Dmi]necej#c[Ami]tíš \
  máš týden #c[Ami]hlad, ž#c[G]ízeň v #c[Ami7]blátě s#c[Ami]píš \
  musíš jít, #c[Ami/G]jen to ne#c[Dmi7]vzdávej, tak #c[Ami7]šlapej #c[E7]dál #c[Ami] \
]

#chorus[
  Jen #c[E]dál, jen #c[Ami]dál \
  na zádech v ranci máš jen bídu svou \
  tak #c[E7]jen šlap#c[Ami]ej dál \
]

#verse[
  Když máš dřít na šlichtu mizernou \
  svý známý v lochu, holku nevěrnou \
  můžeš klít, jen to nevzdávej, šlapej dál \
]

#verse[
  Když máš pech toho kdo nekejvá \
  tvejch slavnejch kamarádů ubejvá \
  pak sám víš, těm už nescházíš, šlapej dál \
]

#verse[
  Je nás víc, nemáme zastání, \
  jen špatnou barvu, špatný vyznání \
  černej mrak, který narůstá, šlapej dál \
]

#verse[
  Jen dál, jen dál...
]


