#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Lesní chata (2025)],
  doc,
)

#verse[
  Já pořád #c[G]vzpomínám si ještě na ten #c[D]čas,\
  bylo tam #c[C]děvče mělo krásný něžný #c[D]hlas,\
  #c[Ami]fóry tahal jsem z ruky, #c[C]s kytarou zpíval sloky,\
  #c[G]a pak jsem odjel #c[D]zas...
]

#chorus[
  #c[Ami]Vracím se do chaty, #c[C]vracíme se do chaty,\
  #c[G]já i můj #c[D]společ#c[Emi]ník chytrák ušatý,\
  #c[Ami]dívka už není #c[D]tam,\
  (jsem) #c[Emi7]sám sám #c[C]sám, jedu tam #c[G]sám.
]

#verse[
  Nosit dubový lístek je čest veliká,\
  pláštěnka, luk a nože jsou výbava má,\
  koník mým přítelem je, bez výhrad ochrání mě,\
  nepřítel naříká.
]

#chorus[
  Vracím se do chaty, vracíme se do chaty,\
  neměl jsem v úmyslu, pozdě se navrátit,\
  čas plyne rychlejš než se zdá,\
  (teď) sám, sám, sám, jsem tady sám.
]

#verse[
  Hraničářský sbor je pro mě rodinou,\
  žádný cíl už moje šípy neminou,\
  ten kdo je pod kapucí, pláštěnce věřit musí,\
  když se plíží krajinou.
]

#chorus[
  Vracím se do chaty...
]

#verse[
  Oběti přinášet však musí každý z nás,\
  přísaha poutá naše srdce chránit vás,\
  tajemno nás obklopuje, od ostatních distancuje,\
  to je zkrátka úděl náš.
]

#chorus[
  Vracím se do chaty...
]

