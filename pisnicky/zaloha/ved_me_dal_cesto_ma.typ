#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Veď mě dál, cesto má],
  author: [Pavel Bobek],
  doc,
)

#solo[
  G Emi D C
]

#verse[
  #c[G]Někde v dálce, #c[Emi]cesty končí,\
  #c[D]každá prý však #c[C]cíl svůj #c[G]skrývá.\
  #c[G]Někde v dálce, #c[Emi]každá má svůj cíl,\
  #c[D]ať je pár mil dlouhá, #c[C]anebo tisíc #c[G]mil.
]

#chorus[
  Veď mě #c[G]dál, cesto #c[D]má, veď mě #c[Emi]dál, vždyť i #c[C]já,\
  tam, kde #c[G]končíš, chtěl bych #c[D]dojít, veď mě #c[C]dál, cesto #c[G]má.
]

#verse[
  Chodím dlouho, po všech cestách,\
  všechny znám je, jen ta má mi zbývá.\
  Je jak dívky, co jsem měl tak rád,\
  plná žáru bývá, hned zas samý chlad.
]


#chorus[
  Veď mě dál, cesto má...
]

#bridge[
  #c[Emi]Pak na pat#c[D]ník posled#c[G]ní napíšu křídou\
  #c[C]jméno své, a #c[G]pod něj, že jsem #c[D]žil hrozně rád.\
  #c[Emi]Písně své, co mi #c[F]v kapsách zbydou,\
  #c[C]dám si bandou #c[G]cvrčků hrát a #c[D]půjdu spát, půjdu #c[D7]spát.
]

#chorus[
  Veď mě dál, cesto má...
]

#chorus[
  Veď mě dál, cesto má...
]

#chorus[
  Veď mě #c[C]dál, cesto #c[G]má,\
  veď mě #c[D]dál, cesto #c[G]má.
]

