#solo[A D A D]

#verse[
  #c[A]Zapal ten oheň ve mně. #c[D]Čeho se bojíš? #c[A]Zápalkou škrtni jemně.#c[D]\
  Zapal ten oheň ve mně. Čeho se bojíš? Zimou se celá třeseš, proč venku stojíš.\
  Pojď dál, prosím tě nenech se, prosit se dá-ál -- nenech se!
]

#bridge[
  #c[A]Ó-ó-ó-#c[D]óó, #c[A]ó-ó-ó-#c[D]óó.
]

#verse[
  Sedíme na pavlači, přichází ráno, tobě se lesknou oči.\
  Sedíme na pavlači, přichází ráno a mně se hlava točí.\
  Pojď dál, prosím tě nenech se, prosit se dá-ál -- nenech se!
]

#chorus[
  #c[F\#mi]Hodiny se zastaví a v #c[E]devět třicet v pondělí,
  #c[A]Magdaléno, tvoje vlasy,\
  #c[F\#mi]leží pod mou postelí a #c[E]i když jsme to nechtěli,
  #c[A]oblíkáš se, pročpak asi?\
  #c[F\#mi]Hodiny se zastaví a v #c[E]devět třicet v pondělí jsem #c[A]sám.#c[D A D]
]

#verse[
  Stojíme na rozcestí a zvony zvoní, daleko od bolestí.\
  Stojíme na rozcestí a zvony zvoní, možná nás čeká štěstí.\
  Pojď dál. Prosím tě nenech se. Prosit se dá-ál -- nenech se!
]

#chorus[
  #rep[Hodiny se zastaví...]
]

#chorus[
