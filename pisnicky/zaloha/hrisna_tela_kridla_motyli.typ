#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Hříšná těla, křídla motýlí],
  author: [Aneta Langerová],
  line_spacing: 0.5em,
  font_size: 0.9em,
  doc,
)

// TODO: Pozice akordů v druhé části

#solo[H Hsus2 H Hsus2]

#verse[
  #c[H]Jednou už tě málem měla #c[F\#]a už zase by tě chtěla\
  #c[G\#mi]Hříšná těla, křídla motý#c[E]lí\
  Krev stéká #c[H]po růži cos na zeď věšel\
  #c[F\#]Průvan sfouk a život nešel\
  #c[G\#mi]Potrhaná křídla motý#c[E]lí
]

#chorus[
  Vyhni se #c[F\#]botám, který vůní šlapou\
  #c[G\#mi]Drtí řádky psané za pou#c[G\#]hou jen skývu málem zlatou\
  #c[C\#mi]Prodají tě do výkladních #c[E]skří#c[H]ní, výstav#c[F\#]ních sí#c[G\#mi]ní\
  A každej #c[E]zvlášť do kapsy #c[H]svý Jeepem si #c[F\#]pádí
]

#verse[
  Jednou už tě málem měla, za duši tě podržela\
  Hříšná těla, křídla motýlí\
  Navrať se skálou, kterou‘s z cesty sešel\
  Otoč kamenem, kde‘s vešel\
  Napni slunci křídla motýlí
]

#chorus[
  Vyhni se botám...
]

// TODO: Fix offset
#verse[
  #c[C\#]Až vyroste strom#c[D\#mi], #s[E]až udeří do něj blesk a hrom\
  #c[H]Hmmm, noc se #c[F\#]válí\
  #c[C\#]Až vyroste strom#c[D\#mi], #s[E]a udeří do něj blesk a hrom\
  #c[F\#]Narovná, rozdělí, podělí\
  Poskládáš úterý ke kusům nedělí a půjdeš #c[H F\# G\#mi E]dál
]

#verse[
  Vzpomeň si na svět\
  Kdy pro kousek těla\
  Zázraky jsi neviděla\
  Neměla jsi křídla motýlí\
  V roklině pod skálou zjevení\
  Údolí rozšklebené napětím, otevřené spojením\
  Jeleni obtěžkáni vábením\
  Vrhají se bezhlavě do hloubi země
]

