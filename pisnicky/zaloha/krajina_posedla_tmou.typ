#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Krajina posedlá tmou],
  author: [Jiří Suchý, Jiří Šlitr],
  note: [
    #set text(size: 0.9em)
    _Originál: každou sloku transponuj o~tón nahoru_
  ],
  doc,
)

#verse[
  #c[G]Krajina #c[C]posedlá #c[G]tmou,#c[C G]\
  #c[G]vzpomínky #c[C]do sedla #c[G]zvou,#c[C G]\
  #c[G]nutí mě vrátit se #c[D7]tam,\
  #c[D7]kde budu navěky sám,\
  #c[D7]kde místo úsměvů #c[G]tvých\
  #c[H]čeká jen řada snů #c[Emi]zlých,\
  #c[C]a místo #c[Cmi]lásky nas #c[G]dvou,#c[C G]\
  #c[G]krajina #c[D7]posedlá #c[G]tmou.#c[C G]
]

#verse[
  Když západ v očích mi plál,\
  s tebou jsem naposled stál,\
  i když jsi čekala víc,\
  přijel jsem tenkrát ti říct,\
  že mám tě na každý pád, jedinou na světě rád,\
  a pak jsem zase jel dál,\
  když západ v očích mi plál.
]

#verse[
  Proč jsem se vracel tak rád,\
  proč jsem měl touhu se smát,\
  když cestou řekli mi: Joe,\
  ta nikdy nebude tvou,\
  že láska mizí jak dým, to dneska proklatě vím,\
  jedno však musím se ptát,\
  proč jsem se vracel tak rád?
]
