#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Dajána],
  author: [Zdeněk Borovec],
  doc,
)

#verse[
  #c[G]Lidé o ní #c[Emi]říkají, #c[C]že je v lásce #c[D7]nestálá,\
  #c[G]ona zatím #c[Emi]potají #c[C]jediného v #c[D7]mysli má.\
  #c[G]Na toho, kdo #c[Emi]klid jí vzal, #c[C]dnem i nocí #c[D7]čeká dál,\
  #c[G]krás#w[Emi]ná, #s[C]bláho#w[D7]vá Da#c[G]jána.#c[Emi C D7]
]


#verse[
  Ten, kdo jí klid navždy vzal, odešel si bůhvíkam,\
  Dajána má v srdci žal, žije marným vzpomínkám,\
  předstírá-li ve dne smích, pláče v nocích bezesných,\
  krásná, bláhová Dajána.
]

#chorus[
  #c[C]Srdce které #c[Cmi]zastesklo si, #c[G]s úsměvem teď #c[G7]žal svůj nosí\
  #c[C]stále čeká, #c[Cmi]čeká dál, o, #c[D]o, o o #c[D7]o o o...
]

#verse[
  Ospalá jde ulicí, nezbaví se lásky pout,\
  sny, jež voní skořicí, sny, jež nelze obejmout,\
  navždy bude sama snít, nenalezne nikdy klid,\
  krásná, bláhová Dajána.
]

#chorus[
  Srdce které zastesklo si, s úsměvem teď žal svůj nosí\
  stále čeká, čeká dál, o-o, o-o, o-o-o-o-o-o-o-o-o
]

#verse[
  Ospalá jde ulicí, nezbaví se lásky pout,\
  sny, jež voní skořicí, sny, jež nelze obejmout,\
  navždy bude sama snít, nenalezne nikdy klid,\
  krásná, bláhová Dajána.\
  Da#c[G]jána.#c[Emi C D7]\
  Da#c[G]jána.#c[Emi C D7 G]
