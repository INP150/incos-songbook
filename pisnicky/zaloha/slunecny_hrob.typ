#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Slunečný hrob],
  author: [Vladimír Mišík],
  doc,
)

#set par(leading: 0.5em)
#set text(size: 0.9em)

// Aby se vešlo na jednu stránku
// TODO: Recitace\
#verse[
  #c[E]Usínám a #c[F\#mi]chtěl bych se vrátit\
  o #c[G\#mi]nějakej ten rok #c[F\#mi]zpátky\
  #c[E]bejt zase malým #c[F\#mi]klukem\
  kterej si #c[G\#mi]rád hraje, který je #c[F\#mi]s #c[E]tebou
]

#verse[
  #c[E]Zdá se #c[F\#mi][mi] #c[G\#mi]je to #s[F\#mi]moc let\
  #c[E]já byl #c[F\#mi][kluk,] #c[G\#mi]kterej #c[F\#mi]chtěl\
  #c[E]Znáti #c[F\#mi]svět #s[G\#mi]s tebou #c[F\#mi]jsem si #c[E]hrál.
]

#verse[
  Vrátím se a chtěl bych rád\
  být s tebou zavzpomínat\
  Mám tu teď  ale zprávu zlou
]

#chorus[
  #c[C\#mi]Su#w[D\#mi]chá #s[A]hlína #c[G\#mi]ta#w[F\#mi]dy\
  #c[C\#mi]Bez #s[D\#mi]kví#w[A]tí, bez #c[G\#mi]vo#w[F\#mi]dy\
  #c[G\#mi]Já na ní #c[F\#mi]poklekám, #c[G\#mi]vzpomínkou poc#c[H]ta se vzdává
]

#verse[
  Loučím se a něco však tam zůstalo\
  z těch našich dnů\
  a já teď vím, věrný zůstanu
]

#chorus[
  Suchá hlína tady...
]

#verse[
  Loučím se a něco však tam zůstalo\
  z těch našich dnů\
  já teď vím, věrný zůstanu
]

#verse[
  Nemohu spát a probouzím se\
  a zase se nemohu ubránit myšlence vrátit se o nějakej ten rok zpátky\
  bejt zase malým klukem, který si rád hraje, který je s tebou.
]

