#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Námořnická],
  author: [Karel Plíhal],
  doc,
)

#verse[
  #c[D]Maličký námořník #c[G]v krabičce od mýdla\
  #c[D]vydal se #c[A7]napříč va#c[D]nou.\
  #c[D]Bez mapy, buzoly, #c[G]vesel a kormidla\
  #c[D]pluje za #c[A7]krásnou Ja#c[D]nou.
]

#chorus[
  #c[F\#mi]Za modrým #c[Hmi7]obzorem #c[F\#mi]dva mysy #c[Hmi7][naděje]~\
  #c[E]lákají odvážné #c[A7]kluky.\
  #c[D]Snad právě na něho #c[G]štěstí se usměje,\
  #c[D]cíl má už #c[A7]na dosah #c[D]ruky.
]

#verse[
  Maličký námořník v krabičce od mýdla\
  zpocený tričko si svlíká.\
  Moře je neklidný, Jana je nastydlá,\
  kašle a loďkou to smýká.
]

#chorus[
  Za modrým obzorem...
]

#verse[
  Maličký námořník s vlnami zápasí,\
  polyká mýdlovou pěnu.\
  Loďka se potápí, v takovémto počasí\
  je těžké dobývat ženu.
]

#chorus[
  Za modrým obzorem dva mysy naděje\
  čekají na další kluky.\
  Maličký námořník i študák z koleje\
  mají cíl na dosah ruky.
]

