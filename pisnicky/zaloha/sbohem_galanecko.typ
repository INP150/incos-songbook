#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Sbohem, galánečko],
  author: [Vlasta Redl],
  doc,
)

#verse[
  #c[C]Sbohem, galá#c[Ami]nečko, #c[Dmi]já už musím #c[G~]jí#w[C]ti,#s[D7]\
  #c[G]Sbohem, galá#c[Emi]nečko, #c[Ami]já už musím #c[D~]jí#w[G]ti,#s[G4sus]\
  #rep[
    #c[Dmi]kyselé ví#c[G]nečko, #c[C]kyselé ví#c[Dmi]ne#w[G]čko,\
    #c[C]podalas' mně #c[Dmi]k #s[G]pi#w[C]tí.
  ]
]
#verse[
  #rep[Sbohem, galánečko, rozlučme sa v pánu,]\
  #rep[
    kyselé vínečko, kyselé vínečko,\
    podalas' mně v džbánu.
  ]
]
#verse[
  #rep[Ač bylo kyselé, přecaj sem sa opil,]\
  #rep[
    eště včil sa stydím, eště včil sa stydím,\
    co sem všecko tropil.
  ]
]
#verse[
  #rep[Ale sa něhněvám, žes' mňa ošidila,]\
  #rep[
    to ta moja žízeň, to ta moja žízeň,\
    ta to zavinila.
  ]
]

