#import "/style.typ": style
#show: style

#show: doc => song(
  title: [Husličky],
  author: [Hradišťan],
  doc,
)

#verse[
  #rep[
    #c[C]Čí že ste, husličky, #c[F]či#w[C]e, #c[Dmi]kdo vás tu #c[Ami~]zane#w[G]chal
  ]\
  #c[Dmi7]na trávě #c[G]pová#w[C]lané,#c[F] #s[Dmi]na trávě #c[G]pová#w[C]lané,#c[F]\
  #c[Dmi]u paty #c[Ami]oře#w[G]cha?#c[Dmi Ami G]
]

#verse[
  #rep[A kdože tu trávu tak zválal, aj modré fialy,]\
  #rep[že ste, husličky, samé]\
  na světě zostaly?
]

#verse[
  #rep[A který tu muzikant usnul a co sa mu přišlo zdát,]\
  #rep[co sa mu enem zdálo, bože]\
  že už vjec nechtěl hrát?
]

#verse[
  #rep[Zahrajte, husličky, samy, zahrajte zvesela,]\
  #rep[až sa tá bude trápit,]\
  která ho nechtěla.
]

