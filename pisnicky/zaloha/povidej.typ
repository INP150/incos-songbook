#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Povídej],
  author: [Petr Novák],
  doc,
)

#verse[
  #c[G]Povídej, jestli tě #c[D]má hodně rád, víc než #c[G]já\
  Jestli když večer jdeš #c[D]spát ti polibek #c[G]dá\
  Tak jako #c[Hmi]já, to už je #c[C]dávno, tak poví#c[G]dej, #c[D7]hej poví#c[G]dej
]

#verse[
  Povídej nechal tě být, vždyť měl tě tak rád\
  Nebos ho nechala jít, když šel s jinou spát\
  Tak jako mně, to už je dávno, tak povídej, hej povídej
]

#bridge[
  Áááá Áááá Áááá Áááá Áááá Áááá Áááá
]

#chorus[
  Poví#w[Hmi]dej, #s[G]jestli se ti po mně #c[A]stýská\
  #c[C]Když jdeš večer #c[G]spát\
  #c[G]Jestli když večer se #c[A]blýská\
  #c[C]Nepřestala ses #c[G]bát
]

#verse[
  Povídej, ne já se nevrátím, jdi domů spát\
  Svou lásku ti vyplatím, víc nemůžu dat\
  Jak jsem dál dřív, to už je dávno tak povídej, hej povídej\
  Povídej, povídej, povídej
]

