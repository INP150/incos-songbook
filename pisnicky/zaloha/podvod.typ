#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Podvod],
  author: [Nedvědi],
  doc,
)

#verse[
  #c[Emi]Na dlani jednu z tvých řas, do tmy se #c[Ami]koukám,\
  #c[D]hraju si písničky tvý, co jsem ti #c[G]psal,\
  je skoro #c[Ami]půlnoc a z kostela #c[Ami/C]zvon mi noc připo#c[Emi]míná,\
  půjdu se #c[Ami]mejt a pozhasínám, co bude #c[H7]dál?
]

#verse[
  Pod polštář dopisů pár, co poslalas, dávám,\
  píšeš, že ráda mě máš a trápí tě stesk,\
  je skoro půlnoc a z kostela zvon mi noc připomíná,\
  půjdu se mejt a pozhasínám, co bude dál?
]

#chorus[
  Chtěl jsem to #c[Ami]ráno, kdy naposled snídal jsem s tebou,\
  ti #c[Emi]říct, že už ti nezavolám,\
  pro jednu pitomou #c[Ami]holku, pro pár nocí #c[D]touhy\
  podved jsem #c[G]všechno, o čem doma si #c[H7]sníš,\
  teď je mi to #c[Emi Emi Ami]líto.
]

#verse[
  Kolikrát člověk může mít rád tak opravdu z lásky,\
  dvakrát či třikrát - to ne, i jednou je dost,\
  je skoro půlnoc a z kostela zvon mi noc připomíná,\
  půjdu se mejt a pozhasínám, co bude dál?
]

#chorus[
  Chtěl jsem to ráno...
]

#chorus[
  Chtěl jsem to ráno...
]
