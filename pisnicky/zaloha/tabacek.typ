#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Tabáček],
  author: [Chinaski],
  doc,
)

#set par(leading: 0.5em)

#verse[
  Ha#c[C]ló, kdo je tam, po zaznění tónu,\
  mi #c[F]zanechte zprávy #c[G]a buďte zdrávi.\
  Ha#c[C]ló, nejsem doma, no je to fakt bída,\
  #c[F]volané číslo vám #c[G]neodpovídá.
]

#chorus[
  #c[Dmi]Polevím z vysokejch #c[G]otáček, #c[C]pohoda, klídek a #c[Ami]tabáček\
  půl dne #c[Dmi]noviny číst a pak #c[G]cigáro, #c[C]pohoda klídek a #c[Ami]leháro\
  #c[Dmi]nejspíš jsem jenom #c[G]línej čím dál #c[C]víc.
]

#verse[
  Neřešte to, pane, to je případ ztracenej, \
  doufám jen, že z toho nejste vykolejenej.\
  Dám vám jednu dobrou radu k nezaplacení,\
  neřešte to, pane, tohle nemá řešení.
]

#chorus[
  Polevím z vysokejch otáček, pohoda, klídek a tabáček\
  vzpomínat na to, co se událo, chci to tak mít nejmíň na stálo  \
  nejspíš jsem jenom línej čím dál víc.
]

#verse[
  Volané číslo je odpojené a bude,\
  odpojené, žádný né, že né.\
  Volané číslo včetně mojí tváře,\
  vymažte ze svýho adresáře.
]

#chorus[
  A pokuste se tvářit nešťastně všude se dočítám, že umřu předčasně\
  a taky vím, že obtěžuju okolí, čekám konec, zatím nic nebolí\
  Víceméně se to dobře vyvíjí, život je návykovej a někdy zabíjí
]

#chorus[
  Polevím z vysokejch otáček, pohoda, klídek a tabáček\
  vzpomínat na to, co se událo, chci to tak mít nejmíň na stálo  \
  nejspíš jsem jenom línej čím dál víc.
]

#chorus[
  A pokuste se tvářit nešťastně všude se dočítám, že umřu předčasně\
