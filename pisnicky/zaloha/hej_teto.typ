#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Hej teto!],
  author: [Michal Horák],
  doc,
)

#grid(
  columns: 2,
  row-gutter: 2em,
  verse[
    Měl jsem #c[Ami]hlídat tetě #c[C]křečka,\
    #c[G]dala mi ho se slovy,\
    ať #c[D]u mě chvíli přečká.
  ],

  verse[
    #c[~]Ale křečka uhlídati\
    nelze jen tak lehce,\
    obzvlášť když se vám moc nechce.
  ],

  verse[
    Po pokoji ať si běhá,\
    na gauč jsem si lehnul,\
    vzápětí se ani nehnul.
  ],

  verse[
    Tlačilo mě do zad kromě\
    polštářů i cosi,\
    už se vidim tetu prosit:
  ],
)

#chorus[
  #c[F]Hej teto! #c[C]Já ho zabil.\
  #c[E7]Už se to nestane,\
  #c[Ami]jo, ten už asi nevstane.\
  Hej teto! Nekřič na mě.\
  Já ho prostě neviděl,\
  už dost jsem se nastyděl.\
  Hej #c[F]teto!#c[C E7 Ami F C E7]
]

#grid(
  columns: 2,
  row-gutter: 1em,
  verse[
    Tak jsem kouknul, co mě tlačí,\
    seděl jsem jenom\
    na televizním ovladači.
  ],

  verse[
    Ale křeččí švitoření\
    slyšet není, jenom zvláštní smrad\
    se line od topení.
  ],

  verse[
    Zase se mi dech zatajil,\
    spečeného křečka bych\
    před tetou neobhájil.
  ],

  verse[
    A dřív než tam sebou seknu,\
    měl bych asi vymyslet,\
    jak tetě potom řeknu.
  ],
)

#chorus[
  Hej teto! Já ho zabil...
]

#chorus[
  Hej teto! Já ho fakt zabil.\
  Ten bídák sežral magnet\
  a k topení se přitavil.\
  Hej teto, co na to říci?\
  Můžeš si ho maximálně\
  připnout na lednici.
]

#chorus[
  Hej teto! Já ho zabil...
]
