#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Já budu chodit po špičkách],
  author: [Petr Novák],
  doc,
)

#verse[
  #c[D]Zavři oči #c[G]a jdi spát, #c[Emi]vždyť už bude #c[A]brzo den,\
  #c[D]nech si o mně #c[G]něco zdát, #c[Emi]ať je krásný #c[A]ten tvůj sen.
]

#chorus[
  #c[Emi]Já budu chodit #c[A]po špičkách, #c[Emi]snad tě tím nevzbu#c[A]dím,\
  #c[Emi]ááá, až slunce #c[A]vyjde v tmách, #c[G]polibkem tě #c[A]probudím.
]

#verse[
  Jdi si lehnout, ať už spíš, ať z toho snu něco máš,\
  ráno, až se probudíš, polibek mi taky dáš.
]

#chorus[
  Já budu chodit...
]

#verse[
  Rozhoď vlasy na polštář a sni o mně krásnej sen,\
  nebo ráno nepoznáš, že je tady nový den.
]

#chorus[
  Já budu chodit...
]

