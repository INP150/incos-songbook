#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Černé oči, jděte spát],
  author: [Česká lidová],
  doc,
)

#verse[
  #c[G]Černé oči, jdě#c[D]te #c[G]spát,\
  #c[G]černé oči, jděte spát,\
  #c[Ami]však musíte #c[D7]ráno vstát,\
  #c[G]však musíte #c[D7]ráno #c[G]vstát.
]

#verse[
  Ráno, ráno raníčko,\
  dřív než vyjde sluníčko.
]

#verse[
  Už sluníčko vychází,\
  má milá se prochází.
]

#verse[
  Prochází se po rynku,\
  přinesla nám novinku.
]

#verse[
  To novinku takovou,\
  že na vojnu verbujou.
]

#verse[
  Když verbujou, budou brát,\
  škoda hochů nastokrát.
]

