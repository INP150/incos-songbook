#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Divoké koně],
  author: [Jaromír Nohavica],
  doc,
)

#verse[
  #rep[#c[Ami]Já viděl #c[Dmi]divoké #c[Ami]koně, #c[C]běželi #c[Dmi]soumra#c[Ami]kem,]\
  #c[Dmi]vzduch #c[Ami]těžký #c[Dmi]byl a divně #c[Ami]voněl #c[Ddim]tabá#w[F][kem,]\
  #c[Dmi]vzduch #c[Ami]těžký #c[Dmi]byl a divně #c[Ami]voněl #c[E7]tabá#c[Ami]kem.
]

#verse[
  #rep[Běželi, běželi bez uzdy a sedla krajinou řek a hor,]\
  #rep[sper to čert, jaká touha je to vedla za obzor?]
]

#verse[
  #rep[Snad vesmír nad vesmírem, snad lístek na věčnost,]\
  #rep[naše touho, ještě neumírej, sil máme dost.]
]

#verse[
  #rep[V nozdrách sládne zápach klisen na břehu jezera,]\
  #rep[milování je divoká píseň večera.]
]

#verse[
  #rep[Stébla trávy sklání hlavu, staví se do šiku,]\
  #rep[král s dvořany přijíždí na popravu zbojníků.]
]

#verse[
  #rep[Chtěl bych jak divoký kůň běžet, běžet, nemyslet na návrat,]\
  #rep[s koňskými handlíři vyrazit dveře, to bych rád.]\
  Já viděl divoké koně...
]

