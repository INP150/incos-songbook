#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Nagasaki, Hirošima],
  author: [Mňága a Žďorp],
  doc,
)

#verse[
  #c[C]Tramvají #c[G]dvojkou #c[F]jezdíval jsem #c[G]do Žide#c[C]nic,#c[G F G]\
  #c[C]z tak velký #c[G]lásky #c[F]většinou #c[G]nezbyde #c[Ami]nic,\
  #c[F]z takový #c[C]lásky #c[F]jsou kruhy #c[C]pod oči#c[G]ma,\
  a dvě #c[C]spálený #c[G]srdce – #c[F]Nagasaki, #c[G]Hiroši#c[C]ma.#c[G F G]
]

#verse[
  Jsou jistý věci, co bych tesal do kamene,\
  tam, kde je láska, tam je všechno dovolené,\
  a tam, kde není, tam mě to nezajímá,\
  jó, dvě spálený srdce – Nagasaki, Hirošima.
]

#verse[
  Já nejsem svatej, ani ty nejsi svatá,\
  ale jablka z ráje bejvala jedovatá,\
  jenže hezky jsi hřála, když mi někdy bylo zima,\
  jó, dvě spálený srdce – Nagasaki, Hirošima.
]

#verse[
  Tramvají dvojkou jezdíval jsem do Židenic,\
  z tak velký lásky většinou nezbyde nic,\
  z takový lásky jsou kruhy pod očima,\
  #rep[a dvě spálený srdce – Nagasaki, Hirošima]
]

