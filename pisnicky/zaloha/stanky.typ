#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Stánky],
  author: [František Nedvěd],
  doc,
)

#verse[
  #c[D]U stánků #c[G]na levnou krásu\
  #c[D]postávaj' a #c[Gmi]smějou se času,\
  #c[D]s cigaretou a #c[A]s holkou, co nemá kam #c[D]jít.
]

#verse[
  Skleniček pár a pár tahů z trávy,\
  uteče den jak večerní zprávy,\
  neuměj' žít a bouřej' se a neposlouchaj'.
]

#chorus[
  #c[D7]Jen #c[G]zahlídli svět, maj' #c[A]na duši vrásky,\
  tak #c[D]málo je, #c[Gmi]málo je lásky,\
  #c[D]ztracená víra #c[A]hrozny z vinic neposbí#c[D]rá.
]

#verse[
  U stánků na levnou krásu\
  postávaj', a ze slov a hlasů\
  poznávám, jak málo jsme jim stačili dát.
]

#chorus[
  Jen zahlídli svět...
]

