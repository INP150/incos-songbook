#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Jdou po mně jdou],
  author: [Jaromír Nohavica],
  doc,
)

#verse[
  Býval jsem #c[D]chudý jak #c[G]kostelní #c[D]myš,\
  na půdě #c[F\#mi]půdy jsem #c[G]míval svou #c[A]skrýš,\
  #rep[
    #c[G]pak jednou #c[D]v létě #c[A]řek' jsem si: #c[Hmi][ať,]~\
    #c[G]svět facku#c[D]je tě, a #c[G]tak mu to #c[D]vrať.
  ]
]

#verse[
  Když mi dát nechceš, já vezmu si sám,\
  zámek jde lehce a adresu znám,\
  #rep[
    zlato jak zlato, dolar či frank,\
    tak jsem šel na to do National Bank.
  ]
]

#chorus[
  Jdou po mně, #c[D]jdou, #c[G]jdou, #c[D]jdou,\
  na každém #c[F\#mi]rohu ma#c[G]jí fotku #c[A]mou,\
  #c[G]kdyby mě #c[D]chytli, #c[A]jó, byl by #c[Hmi][ring,]~\
  #c[G]tma jako #c[D]v pytli je #c[C]v celách Sing-#c[G]sing.#c[A D]
]

#grid(
  columns: 2,
  column-gutter: 10pt,
  verse[
    Ve státě Iowa byl od poldů klid,\
    chudičká vdova mi nabídla byt,\
    #rep[
      jó, byla to kráska,\
      já měl peníze,\
      tak začla láska jak z televize.
    ]
  ],
  verse[
    Však půl roku nato řekla mi: "Dost,\
    tobě došlo zlato, mně trpělivost,\
    #rep[
      sbal svých pár švestek\
      a běž si, kam~chceš,"\
      tak jsem na cestě a chudý jak veš.
    ]
  ],
)

#chorus[
  Jdou po mně...
]

#grid(
  columns: 2,
  column-gutter: 10pt,
  verse[
    Klenotník Smith mi do očí lhal,\
    dvě facky slíz' a dal, vše mi dal,\
    #rep[
      a pak jsem vzal nohy na ramena,\
      ten, kdo nemá vlohy, nic~neznamená.
    ]
  ],
  verse[
    Teď ve státě Utah žiju spokojen,\
    pípu jsem utáh' a straním se žen,\
    #rep[
      jó, kladou mi pasti a do pastí špek,\
      já na ně mastím, jen ať mají vztek.
    ]
  ],
)

#chorus[
  Jdou po mně...
]

