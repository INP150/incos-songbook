#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Tři citrónky],
  author: [Maxim Turbulenc],
  doc,
)

#verse[
  #c[C]V jedné #c[Ami]mořské #c[Dmi]pusti#c[G]ně #c[C]ztroskotal #c[Ami]parník v #c[Dmi]hlubi#c[G]ně,\
  #c[C]jenom tři #c[Ami]malé #c[Dmi]citrón#c[G]ky zůstaly na hladi#c[C]ně.
]
#chorus[
  #rep[#c[C]Rýbaroba, #c[Ami]rýbaroba, #c[Dmi]rýbaroba #c[G]ču ču]... (zůstali na hladi#c[C]ně)
]
#verse[
  Jeden z nich povídá: přátelé,netvařte se tak kysele\
  vždyt' je to přece veselé, že nám patří moře celé.
]
#chorus[
  Rýbaroba, rýbaroba, rýbaroba ču ču, ...
]
#verse[
  tak se citrónky plavily dál, jeden jim k tomu na kytaru\
  hrál, a tak se plavily do dáli, až na ostrov korálový.
]
#chorus[
  Rýbaroba, rýbaroba, rýbaroba ču ču, ...
]
#verse[
  Tam je však stihla nehoda zlá, byla to mořská příšera,\
  sežrala citrónky i s kůrou, zakončila tak baladu mou
]
#chorus[
  Rýbaroba, rýbaroba, rýbaroba ču ču, ...
]

