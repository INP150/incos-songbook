#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Afričančata],
  author: [Jaromír Nohavica],
  doc,
)

#verse[
  V #c[C]Africe, tam žijou sloni #c[Ami~]a po#w[Dmi]dobná #c[G]zvířa#c[C]ta,\
  #c[C]mezi stromy je tam ho#c[Ami]ní Afri#c[Dmi]čan#w[G]ča#w[C]ta,\
  #c[F]načančané #c[G]Afričanče #c[C]jako #c[Dmi]uhel černé #c[G]je,\
  #c[C]ráno skočí na saranče #c[Ami]a je#w[Dmi]de do #c[G]Guine#c[C]je.
]

#verse[
  Děvčata tam honí kluky a kluci zase děvčata,\
  k nám to mají trochu z ruky, Afričančata,\
  přes moře a přes potoky, dva tisíce šestset mil,\
  na kole tak dva-tři roky, no a pěšky ještě dýl.
]

#verse[
  Průšvih je, když Afričanče černé jak mé boty\
  narodí se naší Anče od nás z Dolní Lhoty,\
  ale narodí či nenarodí, vždyť je to vlastně putna,\
  hlavně, že nám nemarodí a že mu u nás chutná, na na na ...
]

