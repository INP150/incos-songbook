#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Na kolena],
  author: [Ivan Hlas],
  doc,
)

#verse[
  Táhněte #c[C]do háje, všichni #c[Ami]pryč,\
  chtěl jsem jít #c[C]do ráje a nemám #c[Ami]klíč,\
  jak si tu #c[C]můžete takhle #c[Ami]žrát,\
  ztratil jsem #c[F]holku, co ji mám #c[G]rád.
]

#verse[
  Napravo, nalevo, nebudu mít klid,\
  dala mi najevo, že mě nechce mít,\
  zbitej a špinavej, tancuju sám,\
  váš pohled káravej už dávno znám.
]

#chorus[
  Pořád jen #rep[#c[F]na kolena, na kolena,] #c[C]jé jé jé,\
  pořád jen #rep[#c[F]na kolena, na kolena,] #c[C]jé jé jé,\
  pořád jen #rep[#c[F]na kolena, na kolena,] #c[C]je to #c[Ami]tak,\
  a vaše #c[F]saka vám posere #c[G]pták.
]

#verse[
  Cigáro do koutku si klidně dám,\
  tuhletu pochoutku vychutnám sám,\
  kašlu vám na bonton, vejmysly chytrejch hlav,\
  sere mě Tichej Don a ten váš tupej dav.
]

#chorus[
  Pořád jen na kolena, na kolena, ...\
  a tenhle barák vám posere pták.
]

