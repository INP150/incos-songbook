#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Zamilovaný princ],
  author: [Tomáš Klus],
  doc,
)

#verse[
  #c[D]Co s touhle šťastnou #c[A]chvílí,\
  to #c[Hmi]když se náhle #c[G]v srdci láska #c[A]ozý#c[D]vá.\
  #c[D]Po noci je den #c[A]bílý,\
  já #c[Hmi]nevím jak se #c[G]druhé srdce #c[A]dobý#c[D]vá.
]
#chorus[
  Jak #c[G]jí, to #c[A]říct, že jen #c[D]o ni v noci #c[Hmi]sním,\
  že jsem #c[G]verš, co k sobě #c[A]našel #c[D]rým.\
  Jak #c[G]jí, to #c[A]říct, jak se #c[D]svěřit s tajem#c[Hmi]stvím,\
  že jsem #c[G]kuchtík s pasem #c[A]králov#c[D]ským.
]
#verse[
  Vyhlašte troubou hlásnou,\
  že je mi jedno, že se prý k ní nehodím.\
  Pro tuhle dívku krásnou,\
  já klíďo píďo, rodokmen svůj zahodím.
]
#chorus[
  Jak jí, to říct...
]

