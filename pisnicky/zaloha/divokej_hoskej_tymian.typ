#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Divokej hoskej tymián],
  author: [Žalman],
  doc,
)

#verse[
  #c[D]Dál za vozem #c[G]spolu #c[D]šlapem,\
  někdo #c[G]rád a někdo #c[D]zmaten,\
  kdo se #c[G]vrací, není #c[F\#mi7]sám,\
  je to #c[Emi]věc, když pro nás #c[G]voní\
  z hor di#c[D]vokej #c[G]tymi#c[D]án.
]


#verse[
  Léto, zůstaň dlouho s námi,\
  dlouho hřej a spal nám rány,\
  až po okraj naplň džbán,\
  je to věc, když pro nás voní\
  z hor divokej tymián.
]


#chorus[
  #c[D7]Podí#c[G]vej, jak málo #c[D]stačí, když do #c[G]vázy natr#c[F\#mi7]hám\
  bílou #c[Emi]nocí k milo#c[G]vání z hor di#c[D]vokej #c[G]tymi#c[D]án.
]


#verse[
  Dál za vozem trávou, prachem,\
  někdy krokem, někdy trapem,\
  kdo se vrací dolů k nám,\
  je to věc, když pro nás voní\
  z hor divokej tymián.
]

#chorus[
  Podívej, jak málo stačí...
]
