#chorus[
  #ca[D]Nosí kalhoty #ca[A]dole široký,\
  #ca[A]vlněný svetr přes #ca[D]suchý boky,\
  #ca[D]Když zapadá večer za #ca[A]hory sluníčko,\
  #ca[A]Ona čeká na něho a #ca[D]plete mu tričko.
