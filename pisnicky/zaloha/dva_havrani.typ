#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Dva havrani],
  author: [Asonance],
  doc,
)

#verse[
  Když jsem se z #c[Dmi]pole #s[C]vrace#c[Dmi]la,\
  dva havrany jsem #c[C]slyše#c[Dmi]la,\
  jak jeden #c[F]druhého se #c[C]ptá:\
  #rep[#c[Dmi]kdo dneska veče#c[C]ři nám #c[Dmi]dá?]
]

#verse[
  Ten první k druhému se otočil\
  a černým křídlem cestu naznačil,\
  krhavým zrakem k lesu hleděl\
  #rep[a takto jemu odpověděl:]
]

#verse[
  "Za starým náspem, v trávě schoulený\
  tam leží rytíř v boji raněný,\
  a nikdo neví, že umírá,\
  #rep[jen jeho kůň a jeho milá."]
]

#verse[
  "Jeho kůň dávno po lesích běhá\
  a jeho milá už jiného má,\
  už pro nás bude dosti místa,\
  #rep[hostina naše už se chystá."]
]

#verse[
  "Na jeho bílé tváře usednem\
  a jeho modré oči vyklovem,\
  a až se masa nasytíme,\
  #rep[z vlasů si hnízdo postavíme."]
]
