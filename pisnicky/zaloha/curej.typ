#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Čůrej],
  author: [Kašpárek v rohlíku],
  line_spacing: 0.5em,
  doc,
)

#solo[D G D D G D]

#verse[
  Čůrej sem a čůrej #c[D]tam #c[G D]\
  Čůrej jako velkej #c[D]pán #c[G D]\
  Ve stoje i za bě#c[G]hu #c[F G]\
  Žlutý srdce do sně#c[D]hu #c[G D]\
  Každej se rád vyčů#c[A]rá #c[A A7]\
  Za dara i za bů#c[D]ra #c[G D]
]

#verse[
  Čůrej sem, sem, sem\
  Čůrej dovnitř čůrej ven\
  Řekni si kam čůrat mám\
  Já se ti tam vyčůrám\
  Ať jseš s partou nebo sám\
  Čůrej sem a čůrej tam
]

#chorus[
  Ať jseš velkej nebo malej\
  Do sklenice vodu nalej\
  Ten kdo hodně vody lemtá\
  Přečůrá i prezidenta\
  A když nevíš kudy kam\
  Čůrej sem a čůrej tam
]

#verse[
  Čůrej doma, čůrej v metru\
  // ({\it hlavně rychle, ještě dneska})\
  Jen nečůrej proti větru\
  // ({\it skvělej výkon všichni tleskaj!})\
  Malý ještě nevinný\
  // ({\it dělej tam čůrej sem })\
  Můžou čůrat do plíny\
  // ({\it na plech pěkně s rámusem})\
  Ať jseš s partou nebo sám\
  // ({\it co je zas tu v parku vidim lidi})\
  Čůrej sem a čůrej tam\
  // ({\it holky se maj můžou sedět})
]

#chorus[
  Ať jseš velkej nebo malej...\
  // ({\it kde je záchod běžim tryskem})\
  // Do sklenice vodu nalej \
  // ({\it pěkně v klidu jdu si s pískem})\
  // Ten kdo hodně vody lemtá \
  // ({\it někdo radši pije LIMO})\
  // Přečůrá i prezidenta \
  // ({\it kdo to umí čůrat limo})\
  // A když nevíš kudy kam \
  // ({\it ty co běhaj za maminkou})\
  // Čůrej sem a čůrej tam \
  // ({\it dávaj bacha na prkýnko})
]

#verse[
  Čůraj češi, čůraj němci \
  // ({\it čůráme a to je daný})\
  Borky, trubky, vytlemenci \
  // ({\it my jsme rádi vyčůraný})\
  Někdy kýbl někdy deci \
  // ({\it když se cejtíš jako v kleci})\
  Pro dnešek mám dobrej plán \
  // ({\it pokračujem sbal si věci})\
  Čůrat sem a čůrat tam
]

