#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Tulácký ráno],
  author: [Jan Nedvěd],
  doc,
)

#verse[
  #c[Ami]Posvátný je mi každý ráno,\
  #c[Emi]když ze sna budí šumící #c[Ami]les\
  #c[Ami]a když se zvedám s písničkou známou\
  #c[Emi]a přezky chřestí o skalnatou #c[Ami]mez.
]
#chorus[
  #c[Ami]Tulácký ráno na kemp se snáší,\
  #c[F]za chvíli půjdem #c[G]toulat se #c[C]dál,\
  #c[Ami]a vodou z říčky oheň se zháší,\
  #c[F]tak zase půjdem #c[G]toulat se #c[Ami]dál.
]
#verse[
  Posvátný je můj každý večer,\
  když oči k ohni vždy vrací se zpět,\
  tam mnohý z pánů měl by se kouknout\
  a hned by věděl, jakej chcem svět.
]
#chorus[
  Tulácký ráno...
]
#verse[
  Posvátný je mi každý slovo,\
  když lesní moudrost a přírodu zná,\
  bobříků sílu a odvahu touhy,\
  kolik v tom pravdy, však kdo nám ji dá?
]
#chorus[
  Tulácký ráno...
]
#chorus[
  Tulácký ráno...
]

