#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Karavana mraků],
  author: [Karel Kryl],
  line_spacing: 0.5em,
  doc,
)

#verse[
  #c[D]Slunce je zlatou skobou #c[Hmi]na obloze přibitý,\
  #c[G]pod sluncem #c[A]sedlo kože#c[D]ný,#c[A7]\
  #c[D]pod sedlem kůň, pod koněm #c[Hmi]moje boty rozbitý\
  #c[G]a starý #c[A]ruce sedře#c[D]ný.#c[D7]
]

#chorus[
  Dopředu #c[G]jít s tou #c[A]karavanou #c[Hmi]mraků,\
  schovat svou #c[G]pleš pod #c[A]stetson #c[Hmi]děravý,\
  #rep[
    jen kousek #c[Emi]jít, jen #c[A7]chvíli, #c[Hmi]do soumraku,#c[Emi]\
    až tam, kde #c[Hmi]svítí město, město #c[F\#]bělavý.#c[Hmi]
  ], #s[A7]jééé
]

#verse[
  Vítr si tiše hvízdá po silnici spálený,\
  v tom městě nikdo nezdraví,\
  šerif i soudce - gangstři, voba řádně zvolení\
  a lidi strachem nezdravý.
]


#verse[
  Sto cizejch zabíječů s pistolema skotačí\
  a zákon džungle panuje, je jé jé\
  provazník plete smyčky, hrobař kopat nestačí\
  a truhlář rakve hobluje.
]

#chorus[
  V městě je řád a pro každého práce,\
  buď ještě rád, když huba voněmí,\
  #rep[
    může tě hřát, že nejseš na voprátce\
    nebo že neležíš pár inchů pod zemí.
  ]\
]

#verse[
  Slunce je zlatou skobou na vobloze přibitý,\
  pod sluncem sedlo kožený,\
  pod sedlem kůň, pod koněm moje boty rozbitý\
  a starý ruce sedřený.
]

#chorus[
  Pryč odtud jít s tou karavanou mraků,\
  kde tichej dům a pušky rezaví,\
  #rep[
    orat a sít od rána do soumraku\
    a nechat zapomenout srdce bolavý.
  ]
]

