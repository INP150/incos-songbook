#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Miluju a maluju],
  author: [Václav Neckář],
  doc,
)

#section[
  _#c[Emi]Dejte mi #c[Hmi]malíři #c[C]barvy všech #c[D]druhů\
  #c[Emi]Já budu #c[Hmi]do mraků #c[C]malovat #c[D]duhu\
  #c[Emi]Řekněte básnici #c[Hmi]jak se verš skládá\
  #c[C]Ona mne ona mne asi má #c[D]ráda._
]

#verse[
  Já #c[C]nejsem ani Leonardo ani Michelangelo\
  #c[D]paletu mám amatérsky chudou\
  #c[Ami]ale když mne paní můza políbila na čelo\
  #c[D]Rozhod jsem se skoncovati #c[G]s nudou
]

#chorus[
  #c[C]Samým #c[F]blahem, #c[C]jedním #c[F]tahem\
  #c[C]srdce #c[D]z lásky #c[F]malu#c[G]ju.\
  #c[C]Proto#c[F]že já, #c[C]proto#c[F]že já,\
  #c[C]proto#c[D]že já #c[F]milu#c[G]ju.\
  A #c[C]miluju a #c[F]miluju, a #c[C]miluju a #c[F]miluju\
  a #c[C]miluju a #c[F]maluju a #c[C]miluju a #c[F]maluju.
]

#verse[
  Já neměl nikdy nadání mě nehýčkali uměny\
  Z kreslení jsem vždycky míval pětky.\
  Ale dneska vlastní duší kreslím fresky na stěny\
  fagule mi slouží místo štětky.
]

#chorus[
  Samým blahem, jedním tahem\
  srdce z lásky maluju.\
  Protože já, protože já,\
  protože já miluju.\
  A #c[C]miluju#c[F][~] a #c[C]maluju#c[F][,] a #c[C]miluju#c[F][~] a #c[C]maluju#c[F C F].
]
