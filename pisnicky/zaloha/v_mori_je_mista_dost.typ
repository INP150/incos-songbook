#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [V moři je místa dost ],
  author: [Jaromír Nohavica],
  doc,
)

#chorus[
  #c[C]V moři je místa dost, #c[Dmi]v moři je místa #c[G7]dost,\
  #c[C]v moři je místa, #c[Ami7]místa, ach, místa, #c[Dmi7]v moři je #c[G7]místa #c[C]dost
]

#verse[
  #c[C]Podmořský koník kluše s nákladem mořské pěny,\
  #c[F]cesta je velmi mokrá, #c[G7]a on je unavený,\
  #c[C]za první vlnou vlevo #c[Ami]okolo mořských patní#c[F]ků,\
  na pravo v Golfském proudu #c[G7]už vidí Afriku.
]

#chorus[
  V moři je místa dost...
]

#verse[
  V chaluhách pod hladinou perou se chobotnice,\
  na každém chapadle boxerská rukavice,\
  perou se, perou se, vstávají, padají\
  #c[F]a všechny ryby kolem ploutvemi tleskají.
]

#chorus[
  V moři je místa dost...
]

#verse[
  Medúzy průhledné jak výkladní skříň,\
  čím blíž jsou k hladině, tím vidět jsou míň,\
  na vlnách houpají se a když je nikdo nevi#c[F]dí,\
  šťouchají do lehátek, vrážejí do lidí.
]

#chorus[
  V moři je místa dost...
]

#verse[
  Rejnoci placatí jak kuchyňské utěrky\
  šestého každý měsíc dobijou baterky,\
  na mořských křižovatkách blikají světlama,\
  #c[F]aby se nesrazily ryby s rybama.
]

#chorus[
  V moři je místa dost...
]

