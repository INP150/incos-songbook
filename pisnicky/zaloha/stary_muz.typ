#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Starý muž],
  author: [Jaromír Nohavica],
  doc,
)

#verse[
  #c[G]Až budu starým mužem, #c[Hmi]budu staré knihy #c[Emi]číst\
  a mladé #c[C]víno #c[D]lisovat,\
  #c[G]až budu starým mužem, #c[Hmi]budu si konečně #c[Emi]jist\
  tím, #c[C]koho chci #c[D]milovat,\
  #c[G]koupím si pergamen a #c[Hmi]štětec a tuš\
  a jako #c[Emi]čínský mudrc sednu na břeh #c[D]řeky\
  a budu #c[G]starý muž,#c[Hmi Emi C D] #s[G]starý muž.#s[Hmi Emi C D]
]
#verse[
  Až budu starým mužem, pořídím si starý byt\
  a jedno staré rádio,\
  až budu starým mužem, budu svoje místo mít\
  u okna kavárny Avion,\
  koupím si pergamen, štětec a tuš\
  a budu pozorovat lidi, kam jdou asi,\
  a budu starý muž, a budu starý muž.
]
#chorus[
  #c[C C/H Ami C/H C C/H Ami C/H C C/H Ami C/H C C/H D]Na na na ...
]
#verse[
  Až budu starým mužem, budu černý oblek mít\
  a šedou vázanku,\
  až budu starým mužem, budu místo vody pít\
  lahodné víno ze džbánku,\
  koupím si pergamen, štětec a tuš\
  a budu mlčet, jako mlčí ti, kdo vědí už,\
  starý muž, starý muž.
]

