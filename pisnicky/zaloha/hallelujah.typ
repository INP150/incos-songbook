#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Hallelujah],
  author: [Leonard Cohen],
  line_spacing: 0.5em,
  doc,
)

#verse[
  I #c[C]heard there was a #c[Ami]secret chord\
  That #c[C]David played, and it #c[Ami]pleased the Lord\
  But #c[F]you don't really #c[G]care for music, #c[C]do ya?#c[G]\
  Well it #c[C]goes like this, the #c[F]fourth, the #c[G]fifth\
  The #c[Ami]minor fall and the #c[F]major lift\
  The #c[G]baffled King #c[E7]composing "Halle#c[Ami]lujah"
]

#chorus[
  Halle#c[F]lujah, halle#c[Ami]lujah, halle#c[F]lujah, halle#c[C]lujah#c[G C]
]

#verse[
  Your faith was strong but you needed proof\
  You saw her bathing on the roof\
  Her beauty and the moonlight overthrew ya\
  She tied you to her kitchen chair\
  She broke your throne and she cut your hair\
  And from your lips she drew the Hallelujah
]

#chorus[
  Hallelujah...
]

#verse[
  You say I took the name in vain, \
  I don't even know the name \
  but if I did, well really, what's it to ya? \
  There's a blaze of light in every word, \
  it doesn't matter which you heard, \
  the holy or the broken Hallelujah. \
]

#chorus[
  Hallelujah...\
]

#verse[
  I did my best, it wasn't much, \
  I couldn't feel, so I tried to touch, \
  I've told the truth, I didn't come to fool ya. \
  And even though it all went wrong, \
  I'll stand before the Lord of Song \
  with nothing on my tongue but Hallelujah \
]

#chorus[
  Hallelujah...
]

#chorus[
  Hallelujah...
]

