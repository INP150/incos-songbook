#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Co z tebe bude],
  author: [Pokáč],
  capo: 3,
  line_spacing: 0.6em,
  font_size: 0.95em,
  doc,
)

#verse[
  #c[C]Když jsem byl prcek, #c[Dmi]tak se mě všude\
  #c[G]dospěláci ptali chlapče, #c[C]co z tebe bude\
  #c[Ami]já řek, že nevim a #c[Dmi]div se nerozbrečel\
  dyť #c[G]já měl sotva páru, co #c[C]budu dělat večer.
]

#verse[
  Ptala se máma, zajímalo to tetu\
  i zoufalýho dějepisáře v kabinetu\
  jo, kdyby na mě dneska stejnej dotaz měl\
  moc rád bych mu odpověděl... (já pane učitel)
]

#chorus[
  #rep[
    Já chci #c[C]milovat, já chci #c[Dmi]poznat svět,\
    já chci #c[G]lítat na měsíc #c[C]a pak zpět,\
    já chci #c[Ami]drink a pláž ne tvou #c[Dmi]kancelář,\
    tak #c[G]proč se mě tak blbě #c[C]ptáš?
  ]
]

#verse[
  Občas se zdá že účel dospívání\
  je úspěšně se vyvinout ve vzorný plátce daní\
  možná by ale někdy stálo za to říct,\
  že život je i něco víc.
]

#verse[
  Víc než do kanclu z kanclu splácet hypotéku\
  a ke kafi si ráno dát tři cukry a hrst léků\
  život je dar tak žij ho než uteče ti\
  čekáním na důchod ve stopěti
]

#chorus[
  #rep[
    Já chci milovat, já chci poznat svět...
  ]
]


#bridge[
  #c[C]Uo o o #c[Dmi]o co z tebe bude\
  #c[G]Uo o o #c[C]o co z tebe bude\
  #c[Ami]Uo o o #c[Dmi]o co z tebe bude\
  #c[G]Uo o o #c[C]o
]

#chorus[
  #rep[
    Já chci milovat, já chci poznat svět...
  ]
]
