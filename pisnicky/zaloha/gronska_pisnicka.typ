#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Grónská písnička],
  author: [Jaromír Nohavica],
  doc,
)

#verse[
  #c[D]Daleko #c[Emi]na severu #c[A]je Grónská #c[D]zem,\
  #c[D]žije tam #c[Emi]Eskymačka #c[A]s Eskymá#c[D]kem,\
  #rep[
    #c[D]my bychom #c[Emi]umrzli, jim #c[G]není zi#c[D]ma,\
    #c[D]snídají #c[Emi]nanuky #c[A]a esky#c[D]ma.
  ]
]

#verse[
  Mají se bezvadně, vyspí se moc,\
  půl roku trvá tam polární noc,\
  #rep[
    na jaře vzbudí se a vyběhnou ven,\
    půl roku trvá tam polární den.
  ]
]

#verse[
  Když sněhu napadne nad kotníky,\
  hrávají s medvědy na četníky,\
  #rep[
    medvědi těžko jsou k poražení,\
    neboť medvědy ve sněhu vidět není.
  ]
]

#verse[
  Pokaždé ve středu, přesně ve dvě\
  zaklepe na na íglů hlavní medvěd:\
  // TODO: Uvozovky\
  #rep[
    "Dobrý den, mohu dál na vteřinu?\
    Nesu vám trochu ryb na svačinu."
  ]
]

#verse[
  V kotlíku bublá čaj, kamna hřejí,\
  psi venku hlídají před zloději,\
  #rep[
    smíchem se otřásá celé íglů,\
    neboť medvěd jim předvádí spoustu fíglů.
  ]
]

#verse[
  Tak žijou vesele na severu,\
  srandu si dělají z teploměrů,\
  #rep[
    my bychom umrzli, jim není zima,\
    neboť jsou doma a mezi svýma.
  ]
]

