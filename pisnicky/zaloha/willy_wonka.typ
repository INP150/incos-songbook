#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Lilly Wonka (2024)],
  doc,
)

#verse[
  #c[G]Lilly Wonka, Lilly Wonka, tvůrce #c[G]dobrých #c[C]čoko#c[G]lád,\
  #c[G]Lilly Wonka, Lilly Wonka, jemu #c[G]poctu #c[C]chceme #c[G]vzdát,\
  na #c[C]tábor sem k nám #c[G]zavítal a #c[C]obdiv denně #c[G]sklízí,\
  přes #c[C]sladkosti je #c[G]odborník a ú#c[A]spěch mu #rep(repeat: 3)[není #c[D]cizí.]
]

#verse[
  Lilly Wonka, Lilly Wonka, čokoládu dobře zná,\
  Lilly Wonka, Lilly Wonka, dokonalý resept má,\
  u Polomáčenkových čokoládu rádi měli,\
  ochutnali a teď chtějí namočit #rep(repeat: 3)[se celí.]
]

#verse[
  Lilly Wonka, Lilly Wonka, Dupetkovy k sobě vzal,\
  Lilly Wonka, Lilly Wonka, nikdy nezalitoval,\
  když Dupetky do čokolády spolu namočili,\
  o spolupráci do budoucna hnedka #rep(repeat: 3)[jasno měli.]
]

#verse[
  Lilly Wonka, Lilly Wonka, továrnou provází dál,\
  Lilly Wonka, Lilly Wonka, k ochutnávkám všechny zval,\
  když Oplatkovi Wonkovy oplatky okusili,\
  hned jeho tajnou recepturu ukrást #rep(repeat: 3)[mu zkusili.]
]

#verse[
  Lilly Wonka, Lilly Wonka, Perníkovy sleduje,\
  Lilly Wonka, Lilly Wonka, své úspěchy jmenuje,\
  když ho však seznámili s kořením perníkovým,\
  otevřel svou mysl i příchutím #rep(repeat: 3)[zcela novým.]
]

#verse[
  #c[G]Lilly Wonka, Lilly Wonka, končí #c[G]se svou #c[C]továr#c[G]nou,\
  #c[G]čtyři rody, čtyři rody, ji už #c[G]od teď #c[C]ovlád#c[G]nou,\
  tak #c[C]čoko#c[G]ládu #c[C]oslav#c[G]me a #c[C]na po#c[G]čest se #c[C]posta#c[G]vme\
  #c[G]Lilly #c[C]Wonka #c[D]odchá#c[G]zí!
]

