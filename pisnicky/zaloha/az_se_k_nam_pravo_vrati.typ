#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Až se k nám právo vrátí],
  author: [Spirituál kvintet],
  line_spacing: 0.55em,
  doc,
)

#verse[
  Chci #c[Dmi]sluncem být a ne planetou,\
  _#c[A7]až se k nám právo #c[Dmi]vrátí,_\
  chci #c[Dmi]setřást bázeň staletou,\
  _#c[A7]až se k nám právo #c[Dmi]vrátí._
]

#chorus[
  #c[Dmi]Já čekám dál, #c[Dmi]já #s[C]čekám #c[F]dál, #c[B]já čekám #c[A]dál,\
  _#c[A7]až se k nám právo #c[Dmi]vrátí, #c[A]vrátí._\
  #c[Dmi]Já čekám dál, #c[Dmi]já #s[C]čekám #c[F]dál, #c[B]já čekám #c[A]dál,\
  _#c[A7]až se k nám právo #c[Dmi]vrátí._
]

#verse[
  Kam chci, tam půjdu, a co chci, budu číst,\
  _až se k nám právo vrátí,_\
  a na co mám chuť, to budu jíst,\
  _až se k nám právo vrátí._
]

#verse[
  Já nechci už kývat, chci svůj názor mít,\
  _až se k nám právo vrátí,_\
  já chci svůj život jako člověk žít,\
  _až se k nám právo vrátí._\
  A proto zpívám...
]

#chorus[
  Já čekám dál...
]

#verse[
  Chci klidně chodit spát a beze strachu vstávat,\
  _až se k nám právo vrátí,_\
  své děti po svém vychovávat,\ _až se k nám právo vrátí._
]

#verse[
  Už se těším až se narovnám,\
  _až se k nám právo vrátí,_\
  své věci rozhodnu si sám,\
  _až se k nám právo vrátí._\
  A proto zpívám...
]
#chorus[
  Já čekám dál...
]
