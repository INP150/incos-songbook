#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Starý příběh],
  author: [Spirituál kvintet],
  doc,
)

#verse[
  Řek' #c[D]Mojžíš jednou lidu svému "přišel čas,\
  dnes v noci tiše #c[F\#mi]vytratí se #c[G]každý z #c[A7]vás."\
  #c[D]Má#c[D7]vá, #c[G]mává nám #c[D]všem svo#c[A7]bodná #c[D]zem.
]

#verse[
  Já říkám rovnou "každý ať s tím počítá,\
  že naše cesta ke štěstí je trnitá."\
  Mává, mává nám všem svobodná zem.
]

#chorus[
  A #c[D]kdo se bojí vodou jít,\
  ten podle tónů faraónů musí #c[A7]žít.\
  #c[D]Má#c[D7]vá, #c[G]mává nám #c[D]všem svo#c[A7]bodná #c[D]zem.
]

#verse[
  Až první krůček bude jednou za námi,\
  tak nikdo nesmí zaváhat, dát na fámy.\
  Mává, mává nám všem svobodná zem.
]

#verse[
  Pak tenhle vandr všem potomkům ukáže,\
  že šanci má jen ten, kdo má dost kuráže.\
  Mává, mává nám všem svobodná zem.
]

#chorus[
  Kdo se bojí vodou jít...
]

#verse[
  Ten starý příběh z knížky vám tu vykládám,\
  ať každý ví, že rozhodnout se musí sám...\
  Mává, mává nám všem svobodná zem.
]

#chorus[
  Kdo se bojí vodou jít...
]
