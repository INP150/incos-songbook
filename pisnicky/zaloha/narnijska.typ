#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Narnijská (2022)],
  doc,
)

#verse[
  #c[Ami]Projdi se skříní #c[Dmi]se mnou,\
  #c[E]Narnijská říše je #c[Ami]pod ledem.\
  #c[Ami]Jen ten, kdo má víru #c[Dmi]pevnou,\
  #c[E]vzkřísí včas Aslana, #c[E7]společně s ním jaro #c[Ami]přivede.
]

#solo[ Emi Fmaj Emi Fmaj F E7 ]

// TODO: Lepší značení změn v repetici\
#chorus[
  #c[C]Čtyři jsou trůny #c[G]z kamene,\
  #c[Dmi]čtyři jsou koruny #c[Ami]zlace#c[E]né.\
  *#c[Ami]temnota slábne den #c[E]ode dne,*\
  _#c[E7]lidská krev na trůny #c[Ami]usedne._
]

#verse[
  Pod lampou za svítání\
  zanechal Kaspian volání o pomoc.\
  Pro bájný roh uhání,\
  s ospalky na očích Tom, Marek, Bety i Kačí.
]

#bridge[
  A zatím tmou vojáci jdou\
  do boje s armádou Mirazovou.
]

#chorus[
  ... *Petrův meč Miraze podetne.*
]

#verse[
  Sedmero lordů uprostřed vln\
  čeká na vysvobození.\
  Na cestu mořem neznámým\
  vyráží Jitřní poutník hned s prvním světlem denním.
]

#bridge[
  Plachty se dmou, můžeme plout\
  za modrou hvězdou.
]

#chorus[
  ... _nad obzorem je další den, vzhůru za Aslanem!_
]

