#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Lemon Tree],
  author: [Fool's Garden],
  font_size: 0.85em,
  col_gutter: 0.25em,
  cols: 2,
  doc,
)

#verse[
  I'm #c[Ami]sittin' here in the #c[Emi]boring room\
  It's #c[Ami]just another rainy Sunday #c[Emi]afternoon\
  I'm #c[Ami]wastin' my time, I got #c[Emi]nothin' to do\
  I'm #c[Dmi]hangin' around, I'm #c[Emi]waitin' for you\
  But #c[Dmi]nothing ever happens #c[Emi]\
  And I #c[Ami]wonder #c[Emi]
]

#verse[
  I'm drivin' around in my car\
  I'm drivin' too fast, I'm drivin' too far\
  I'd like to change my point of view\
  I feel so lonely, I'm waitin' for you\
  But nothing ever happens\
  And I wonder
]

#chorus[
  I #c[C]wonder how, I #c[G]wonder why\
  #c[Ami]Yesterday, you told me 'bout the #c[Emi]blue, blue sky\
  And #c[F]all that I can #c[G]see is just a yellow #c[C]lemon tree#c[G7]\
  I'm #c[C]turnin' my head #c[G]up and down\
  I'm #c[Ami]turnin', turnin', turnin', turnin', #c[Emi]turnin' around\
  And #c[F]all that I can #c[F\#dim7]see is just another #c[G]lemon tree#c[G7]
]

#bridge[
  Sing\
  #c[Ami]Dap, da-da-da-dam, #c[Emi]di-dap-da\
  #c[Emi]Da-da-da-dam, #c[Dmi]di-dap-da\
  #c[Emi]Dap, di-di-li-#c[Ami]da
]

#colbreak()

#verse[
  #c[~]I'm sittin' here, I missed the power\
  I'd like to go out, takin' a shower\
  But there's a heavy cloud inside my head\
  I feel so tired, put myself into bed\
  Well, nothing ever happens\
  And I wonder
]

#bridge[
  #c[E]Isolation #c[Ami]is not good for me\
  #c[G]Isolation, #c[C]I don't want to #c[E]sit on the lemon tree
]

#verse[
  I'm steppin' around in the desert of joy\
  Maybe, anyhow, I'll get another toy\
  And everything will happen\
  And you wonder
]

#chorus[
  I wonder how, I wonder why\
  Yesterday, you told me 'bout the blue, blue sky\
  And all that I can see is just a yellow lemon tree\
  I'm turnin' my head up and down\
  I'm turnin', turnin', turnin', turnin', turnin' around\
  And all that I can see is just another lemon tree

  And I wonder, wonder, I wonder how, I wonder why\
  Yesterday, you told me 'bout the blue, blue sky\
  And all that I can see (Ah, dip-dip-dip-dip)\
  And all that I can see (Ah, dip-dip-dip-dip)\
  And all that I can see\
  Is just a yellow lemon tree
]

