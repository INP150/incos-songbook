#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Hvězdář],
  author: [UDG],
  doc,
)

#verse[
  #rep[
    Ztrácíš se #c[D]před očima, rosteš jen #c[A]ve vlastním stínu.\
    Každá #c[Emi]další vina, odkrývá #c[Cmaj7]mojí vinu.
  ]
]

#bridge[
  #rep[
    Ve vínu #c[D]dávno nic, ve vínu #c[A]dávno nic nehle#c[Emi Cmaj7]dám.
  ]
]

#chorus[
  #rep[
    Jak luna #c[D]mizíš s nocí v bělostných #c[A]šatech pro nemocné,\
    prosit je #c[Emi]zvláštní pocit, jen ať je #c[Cmaj7]den noc ne.
  ]
]

#bridge[
  #rep[
    Od proseb dávno nic, od proseb dávno nic nečekám.
  ]
]

#verse[
  Na chodbách v bludných kruzích zářivka vyhasíná,\
  já ti do infuzí chci přilít trochu vína.\
  Na nebi jiných sluncí, jak se tam asi cítíš,\
  s nebeskou interpunkcí, jiným tulákům svítíš.
]

#bridge[
  #rep[
    Ve vínu dávno nic, ve vínu dávno nic nehledám.
  ]
]

#chorus[
  #rep[
    Jak luna mizíš s nocí...
  ]
]

#bridge[
  #rep(repeat: 3)[
    Obzor ne#c[D]klesne níž, je ráno #c[A]a ty spíš.\
    Od vlků #c[Emi]odraná hvězdáře #c[G]Giordána...
  ]
  Opouš#c[D]tíš...
]
