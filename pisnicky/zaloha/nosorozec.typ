#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Nosorožec],
  author: [Karel Plíhal],
  doc,
)

#verse[
  #c[Ami]Přivedl jsem domů Božce #c[Dmi]nádhernýho #c[Ami]nosorožce,\
  #c[Dmi]originál #c[Ami]nosorožce, #c[Esdim]koupil jsem ho #c[E7]v hospodě.\
  #c[Ami]Za dva rumy a dvě vodky #c[Dmi]připadal mi #c[Ami]velmi krotký,\
  #c[Dmi]pošlapal mi #c[Ami]polobotky, #c[E7]ale jinak #c[Ami]v pohodě.\
  #c[Dmi]Vznikly menší #c[Ami]potíže #c[E7]při nástupu #c[Ami]do zdviže,\
  #c[Dmi]při výstupu #c[Ami]ze zdviže #c[Esdim]už nám to šlo #c[E7]lehce.\
  #c[Ami]Vznikly větší potíže, #c[Dmi]když Božena #c[Ami]v negližé,\
  #c[Dmi]když Božena #c[Ami]v negližé #c[Esdim (E7)]řvala, že ho #s[E7 (Ami)]nechce.
]

#verse[
  Marně jsem se snažil Božce vnutit toho tlustokožce,\
  originál nosorožce, co nevidíš v obchodech.\
  Řvala na mě, že jsem bohém, pak mi řekla: padej, sbohem,\
  zabouchla nám před nosorohem, tak tu sedím na schodech.\
  Co nevidím - souseda, jak táhne domů medvěda,\
  originál medvěda, tuším značky grizzly.\
  Už ho ženě vnucuje a už ho taky pucuje\
  a zamčela a trucuje, tak si to taky slízli.
]

#verse[
  #c[Ami]Tak tu sedím se sousedem, #c[Dmi]s nosorožcem #c[Ami]a s medvědem,\
  #c[Dmi]nadáváme #c[Ami]jako jeden #c[E7]na ty naše #c[Ami]slepice.
]

