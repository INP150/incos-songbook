#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Jaro dělá pokusy],
  author: [Zdeněk Svěrák a Jaroslav Uhlíř],
  font_size: 0.9em,
  line_spacing: 0.5em,
  doc,
)

#verse[
  #c[D]Jaro dělá pokusy, vystrkuje krokusy.\
  Dříve než se vlády #c[A7]chopí, vystrkuje peri#c[D]skopy.\
  #c[D]Než se jaro osmělí, vystrkuje podběly.\
  Ty mu asi dolů #c[A7]hlásí, čerstvé zprávy o po#c[D]časí.
]

#chorus[
  #c[D7]Jaro! (_Jaro!_)\
  Je to v #c[G]suchu, zima už #c[A7]nemůže, (_zima už #c[D]nemůže_)\
  Stoupá (_Stoupá_)\
  teplota vzduchu, a míza do růže, (_a míza do růže_)\
  Povídám, Jaro! (_Jaro!_)\
  Je to v suchu, vichry už nedujou, (_vichry už nedujou_)\
  Nahlas (_nahlas_) nebo v duchu, lidi se radujou, (_lidi se radujou_)
]

#verse[
  U dopravní cedule, vyrostly dvě bledule.\
  Blízko telegrafní tyče, vyrostli dva petrklíče.\
  Mravenci už pracujou, holky sukně zkracujou.\
  Slunce svítí, led je tenký, jaro, vem si podkolenky.\
]

#chorus[
  Jaro! (_Jaro!_)\
  Je to v suchu, zima už nemůže, (_zima už nemůže_)\
  Stoupá (_Stoupá_)\
  teplota vzduchu, a míza do růže, (_a míza do růže_)\
  Povídám, Jaro! (_Jaro!_)\
  Je to v suchu, vichry už nedujou, (_vichry už nedujou_)\
  Nahlas (_nahlas_) nebo v duchu, lidi se radujou, (_lidi se radujou_)\

  Stromy se #c[A7]radujou, (_stromy se #c[D]radujou_)\
  Keře se radujou, (_keře se radujou_)\
  Ryby se radujou, (_ryby se radujou_)\
  Mouchy se radujou, (_mouchy se radujou_)\
  Myši se radujou, (_myši se radujou_)\
  Okna se radujou, (_okna se radujou_)\
  Dveře se radujou, (_dveře se radujou_)\
  Opice se radujou, (_opice se radujou_)\
  Kočky se radujou, (_kočky se radujou_)\
  Sloni se radujou, (_sloni se radujou_)\
  Ministři se radujou, (_ministři se radujou_)
]

