#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Voda, voděnka],
  author: [Zdeněk Svěrák a Jaroslav Uhlíř],
  doc,
)

#verse[
  #c[C]Voda, #c[G]voděn#c[Ami]ka
  #s[F]hladí #c[C]obláz#c[G]ky.\
  #rep[
    #c[C]Takové je #c[C7]pohlazení,
    #c[F]takové je pohlazení
    #c[C]od #c[G]lás#c[C]ky.
  ]
]

#verse[
  Kdo se té vody jednou napije,\
  #rep[
    ten své srdce neuhlídá,
    ten své srdce neuhlídá,
    ztratí je.
  ]
]

#verse[
  #c[D]Když se #c[A]dvě srd#c[Hmi]ce
  #s[G]šťastně #c[D]potka#c[A]jí,\
  #rep[
    #c[D]na voděnce #c[D7]chladné ledy,
    #c[G]na voděnce chladné ledy
    #c[D]pu#c[A]ka#c[D]jí.
  ]
]

#verse[
  Větře, větříčku,
  běžíš po poli,\
  #rep[
    pofoukej mi mou hlavičku.
    pofoukej mi mou hlavičku,
    ať nebolí.
  ]
]

#verse[
  Já jsem tvá milá,
  ty jsi můj milý,\
  #rep[
    co bychom se o samotě,
    co bychom se o samotě
    trápili.
  ]
]

