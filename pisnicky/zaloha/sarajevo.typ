#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Sarajevo],
  author: [Jaromír Nohavica],
  doc,
)

#verse[
  #c[Emi]Přes haličské pláně #c[Ami/F\#]vane vítr zlý,\
  to #c[H7]málo, co jsme měli, nám #c[Emi]vody sebraly,\
  #c[Emi]jako tažní ptáci, #c[Ami/F\#]jako rorýsi\
  #c[H7]letíme nad zemí, dva #c[Emi]modré dopisy.
]
#chorus[
  #c[Emi]Ještě hoří oheň a #c[Ami]praská dřevo,
  #c[D7/F\#]ale už je čas jít #c[G H7][spát,]~\
  #c[Emi]tamhle za kopcem je #c[Ami]Sarajevo,\
  tam #c[H7]budeme se zítra ráno #c[Emi]brát.
]

#verse[
  Farář v kostele nás sváže navěky,\
  věnec tamaryšku pak hodí do řeky,\
  voda popluje zpátky do moře,\
  my dva tady dole a nebe nahoře.
]
#chorus[
  Ještě hoří oheň...
]
#verse[
  Postavím ti dům z bílého kamení,\
  dubovými prkny on bude roubený,\
  aby každý věděl, že jsem tě měl rád,\
  postavím ho pevný, navěky bude stát.
]
#chorus[
  Ještě hoří oheň...
]

