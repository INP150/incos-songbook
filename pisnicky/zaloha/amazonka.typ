#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Amazonka],
  author: [Hop Trop],
  capo: 2,
  doc,
)

#solo[G C/G G]

#grid(
  columns: 2,
  column-gutter: 3em,
  verse[
    Byly krásný naše #c[G]plány,#c[Gsus4 G]\
    byla jsi můj celej #c[Hmi7 Bmi7 Ami7]svět,\
    čas je vzal a nechal #c[G]rány,#c[Gsus4]\
    #c[Ami7]starší jsme jen o pár #c[D]let.#c[Dsus4 D]
  ],
  verse[
    #c[~]Tenkrát byly děti malý,\
    #c[~]ale život utíká,\
    #c[~]už na "táto" slyší jinej,\
    #c[~]i když si tak neříká.
  ],
)

#chorus[
  Nebe modrý zrcad#c[G]lí se\
  #c[E]v řece, #c[E7]která všechno #c[Ami7]ví,\
  stejnou barvu jako #c[G]měly\
  #c[Ami7]tvoje oči džíno#c[D]vý.#c[Dsus4 D]
]

#grid(
  columns: 2,
  column-gutter: 3em,
  verse[
    Kluci tenkrát, co tě znali,\
    všude, kde jsem s tebou byl,\
    "Amazonka" říkávali,\
    a já hrdě přisvědčil.
  ],

  verse[
    Tvoje strachy, že ti mládí\
    pod rukama utíká\
    vedly k tomu, že ti nikdo\
    "Amazonka" neříká.
  ],
)

#verse[
  Zlatý kráse cingrlátek,\
  jak sis časem myslela\
  vadil možná trampskej šátek,\
  nosit dáls' ho nechtěla.
]

#chorus[
  Teď jsi víla z pane#c[G]láku,\
  #c[E]samá #c[E7]dečka, samej #c[Ami7]krám,\
  já si přál jen, abys #c[G]byla\
  #c[Ami7]pořád stejná, přísa#c[G]hám,#c[Gsus4]\
  #c[Ami7]pořád stejná, přísa#c[G]hám.
]


