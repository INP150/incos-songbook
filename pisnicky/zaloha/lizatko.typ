#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Lízátko],
  author: [Ivan Mládek],
  doc,
)

#verse[
  #c[D]Lízát#c[H7]ko, #s[E7]já našel #c[A7]na zemi #c[D]lízát#c[Dmaj7][ko,]~\
  #c[Hmi]Fdimněkdo ho #c[Fdim]olízal #s[Emi]drobát#w[H7]ko\
  #c[Emi]a já se #c[A7]na něj nezlo#c[D\#dim]bím\
  (já #c[D]nejsem #c[D\#dim]žádná #s[Emi]fajnov#c[A7]ka).
]

#verse[
  To #c[D]lízát#c[H7]ko, #s[E7]lízal #c[A7]kluk, či malé #c[D]robát#c[Dmaj7][ko,]~\
  #c[Hmi]případné #c[Fdim]bacily #c[Emi]v tom suchu a zimě\
  #c[E7]uhynuly zakrát#c[A7]ko\
  (do#c[B7]bře jim #c[A7]tak).
]

#verse[
  Nejlepší #c[D]cukrátko je totiž #c[Ami7]lízátko,\
  #c[D]starého chlapa #c[D7]zanese do doby,\
  #c[G]kdy byl ještě #c[H7]malé holátko\
  (#c[Emi]mám dneska, #c[A7]z pekla štěstí).
]

#verse[
  #c[D]Lízát#c[H7]ko, #s[E7]já #s[A7]našel na zemi #c[D]lízát#c[Dmaj7][ko,]~\
  #c[Hmi]pán za mnou #c[Fdim]má mě za #c[Emi]prasát#c[H7][ko]~\
  #c[Emi]a já se #c[A7]na něj nezlo#c[D]bím.#c[G D]
]

