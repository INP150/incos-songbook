#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Rock'n'roll pro Beethovena],
  author: [Ivan Hlas],
  doc,
)

#verse[
  #c[C]Včera v noci měl jsem divnej sen,\
  #c[F]v tom snu ke mně přišel Beetho#c[C]ven,\
  abych #c[G]prej si s ním šel #c[F]zahrát rock'n'#c[C]roll.
]

#chorus[
  #c[C]Ó jé rock'n'roll. ó jé rock'n'roll,\
  #c[F]ó jé rock'n'roll. #c[C]ó jé rock'n'roll.\
  abych #c[G]prej si s ním šel #c[F]zahrát rock'n'#c[C]roll.
]

#verse[
  Já hned jak blázen poslech jsem ten sen,\
  oblík jsem se a šel za nim ven\
  a celou noc jsme hráli rock’n’roll.
]

#chorus[
  Ó jé rock'n'roll...\
  a celou noc jsme hráli rock’n’roll.
]

#verse[
  Beethoven to asi kdysi hrál,\
  ten to uměl rozjet až jsem řval,\
  jó, ten vám uměl rozjet rock’n’roll
]

#chorus[
  Ó jé rock'n'roll...\
  ten vám uměl rozjet rock’n’roll.
]

#verse[
  Přišlo ráno a já jsem už vstal,\
  kosti mi snad v těle rozlámal,\
  věděl jsem ale, jak hrát rock’n’roll.
]

#chorus[
  Ó jé rock'n'roll...\
  věděl jsem ale jak hrát rock’n’roll.
]

