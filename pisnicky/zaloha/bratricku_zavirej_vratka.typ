  doc,
)

#verse[
  #c[Ami]Bratříčku, nevzlykej, to nejsou #c[C]bubáci,\
  #c[G]vždyť už jsi velikej, to jsou jen #c[E7]vojáci,\
  #c[F]přijeli v hranatých železných maringot#c[E]kách.
]

#verse[
  #ca[Ami]Se slzou na víčku hledíme #ca[C]na sebe,\
  #ca[G]buď se mnou, bratříčku, bojím se #ca[E7]o tebe\
  #ca[F]na cestách klikatých, bratříčku, v polobot#ca[E]kách.
]

#chorus[
  #c[Ami]Prší #s[Emi]a #s[Ami]venku #c[Emi]se #s[Ami]setmě#c[Emi Ami Emi]lo,\
  #c[Ami]tato #s[Emi]noc #s[Ami~~]nebu#w[Emi]de #s[Ami~]krát#w[Emi]ká,\
  #c[Ami]berán#c[Emi]ka #s[F]vlku #c[Ami]se #s[Dmi]zachtě#c[Ami]lo,\
  #c[F]bratříčku, #c[Ami]zavřel jsi #c[E7]vrátka?
]

#verse[
  #ca[Ami]Bratříčku, nevzlykej, neplýtvej #ca[C]slzami,\
  #ca[G]nadávky polykej a šetři #ca[E7]silami,\
  #ca[F]nesmíš mi vyčítat, jestliže nedojde#ca[E]me.
]

#verse[
  #ca[Ami]Nauč se písničku, není tak #ca[C]složitá,\
  #ca[G]opři se, bratříčku, cesta je #ca[E7]rozbitá,\
  #ca[F]budeme klopýtat, zpátky už nemůže#ca[E]me.
]

#chorus[
  #ca[Ami]Prší #sa[Emi]a #sa[Ami]venku #ca[Emi]se #sa[Ami]setmě#wa[Emi]lo,#sa[Ami Emi]\
  #ca[Ami]tato #sa[Emi]noc #sa[Ami]nebu#wa[Emi]de #sa[Ami]krát#wa[Emi]ká,\
  #ca[Ami]berán#ca[Emi]ka #sa[F]vlku #ca[Ami]se #sa[Dmi]zachtě#wa[Ami]lo,\
  #c[F]bratříčku, #c[Ami]zavírej #c[E7]vrátka!\
  #c[Ami~]Zaví#w[G]rej #c[Ami]vrátka!
]

