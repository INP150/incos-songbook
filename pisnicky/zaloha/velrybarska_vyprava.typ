#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Velrybářská výprava],
  author: [Pacifik],
  doc,
)

// TODO: Uvozovky\
#verse[
  #c[C]Jednou plác' mě #c[F]přes rameno #c[G7]Johny zvanej #c[C]Knecht:\
  "#c[Ami]Mám pro tebe, #c[Dmi]hochu, v pácu #c[G7]moc fajnovej #c[C]kšeft!"\
  #c[C]Objednal hned #c[F]litr rumu #c[G7]a pak něžně #c[C]řval:\
  "#c[Ami]Sbal se, jedem #c[Dmi]na velryby, #c[G7]prej až za po#c[C]lár."
]
#chorus[
  #rep[
    Výprava #c[C]velrybářská #c[F]kolem Grónska #c[G7]nezdařila #c[C]se,\
    protože #c[Ami]nejeli jsme #c[Dmi]na velryby, #c[G7]ale na mro#c[C]že.
  ]
]
#verse[
  Briga zvaná Malá Kitty kotví v zátoce,\
  nakládaj' se sudy s rumem, maso, ovoce,\
  vypluli jsme časně zrána, směr severní pól,\
  dřív, než přístav zmizel z očí, každej byl namol.
]
#chorus[
  Výprava velrybářská...
]
#verse[
  Na loď padla jinovatka, s ní třeskutej mráz,\
  hoň velryby v kupách ledu, to ti zlomí vaz,\
  na pobřeží místo ženskejch mávaj' tučňáci,\
  v tomhle kraji beztak nemáš jinou legraci.
]
#chorus[
  Výprava velrybářská...
]
#verse[
  Když jsme domů připluli, už psal se příští rok,\
  starej rejdař povídá, že nedá ani flok:\
  "Místo velryb v Grónským moři zajímal vás grog,\
  tuhle práci zaplatil by asi jenom cvok."
]
#chorus[
  Výprava velrybářská...
]
#verse[
  Tohleto nám neměl říkat, teď to dobře ví,\
  stáhli jsme mu kůži z těla, tomu hadovi,\
  z paluby pak slanej vítr jeho tělo smet', chachacha,\
  máme velryb plný zuby, na to vezmi jed.
]
#chorus[
  Výprava velrybářská...
]

