#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Malagelo],
  author: [Ivan Hlas],
  note: [
    Malagelo je železité mediciální víno.
  ],
  line_spacing: 0.5em,
  font_size: 0.9em,
  doc,
)

#solo[#rep(repeat: 3)[G C D]]

#verse[
  Já #c[G]potkal jsem Tě na ulici, #c[C]byla jsi #c[D]jako #c[G]dělo#c[C D]\
  a #c[G]do tmy svítilo tvoje mladý #c[C]bílý #c[D]smělý #c[G]čelo#c[C D]\
  a #c[G]pod paží sis nesla svoje #c[C]oblíbený #c[D]Mala#c[G]gelo...
]


#chorus[
  #c[G]Mala, mala, #c[C]Mala#c[D]gelo,\
  #c[G]mala, mala, mala, #c[C]Mala#c[D]gelo,\
  #c[G]mala a mala, #c[C]Mala#c[D]gelo,\
  #c[G]mala, mala, mala, #c[C]Mala#c[D]gelo.
]


#verse[
  Já pozval jsem Tě k sobě domů, tenkrát se to ještě smělo,\
  a tam jsem zjistil, že máš hladký, bílý, smělý tělo,\
  a k tomu jsme popíjeli svoje oblíbený Malagelo.
]


#chorus[
  Mala, mala, Malagelo...
]


#bridge[
  Tak #c[G]puč mi puč, #c[C]Mala#c[D]gelo,\
  #c[G]puč mi puč, #c[C]Mala#c[D]gelo.\
  #c[G]puč mi puč, #c[C]Mala#c[D]gééééééé#c[G]lóóóó.#c[C D]
]


#solo[#rep(repeat: 4)[G C D]]

#verse[
  Já potkal jsem Tě na ulici, byla jsi zase jako dělo\
  a do tmy svítilo tvoje mladý bílý smělý čelo\
  a v tašce sis nesla svoje oblíbený Malagelo.
]

#chorus[
  Mala, mala, Malagelo...
]

#bridge[
  Tak puč mi puč, Malagelo,\
  #rep(repeat: 3)[puč mi puč, Malagelo]\
]

#chorus[
  Mala, mala, mala, mala, mala, Malagelo,\
  mala a mala, mala, Malagelo,\
  #rep(repeat: 2)[mala, mala, mala, Malagelo,]\
  #rep(repeat: 2)[mala a mala, Malagelo,]\
  mala, mala, mala, mala, Malagééééélóóó.
]

#bridge[
  Tak puč mi puč, Malagelo...
]
