#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Zafúkané],
  author: [Fleret],
  doc,
)

#verse[
  #c[Ami]Větr sněh #c[A2]zanésl #c[Ami]z hor do po#c[A2]lí,
  #s[Ami]já idu #c[C]přes kopce, #c[G]přes údo#c[Ami]lí,\
  #c[C]idu k Tvej #c[G]dědině zatúla#c[C]nej,
  #c[F]cestičky #c[C]sněhem sú #c[E]zafúka#c[Ami A2 Ami]né.
]

#chorus[
  #c[Ami]Zafúka#c[C]né, #c[G]zafúka#c[C]né, #c[F]kolem mňa #c[C]všecko je #c[Dmi]zafúka#c[E]né.\
  #c[Ami]Zafúka#c[C]né, #c[G]zafúka#c[C]né, #c[F]kolem mňa #c[Dmi]všecko je #c[E]zafúka#c[Ami]né.
]

#solo[
  Emi D G H7 Emi D G H7 Emi
]

#verse[
  Už vašu chalupu z dálky vidím, srdce sa ozvalo, bit ho slyším,\
  snáď enom pár kroků mi zostává, a budu u Tvého okénka stát.
]

#chorus[
  #rep[Zafúkané, zafúkané, okénko k Tobě je zafúkané.]
]

#solo[
  Emi D G H7 Emi D G H7 Emi
]

#verse[
  Od Tvého okna sa smutný vracám, v závějoch zpátky dom cestu hledám,\
  spadl sněh na srdce zatúlané, aj na mé stopy - sú zafúkané.
]

#chorus[
  #rep[Zafúkané, zafúkané, mé stopy k Tobě sú zafúkané.]
]

#solo[
  Emi D G H7 Emi D G H7 Emi
]
