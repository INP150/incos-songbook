#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Nadějí, láskou a vírou],
  author: [Spirituál kvintet],
  doc,
)

#chorus[
  Nadějí #c[D]láskou a vírou, nadějí #c[A]láskou a #c[D]vírou,\
  nadějí #c[D7]láskou a #c[G]vírou, se #c[D]píseň #c[A]může #c[D]stát.
]

#verse[
  Já když #c[D]bejval ještě dítě, táta #c[A]řek čas nau#c[D]čí tě,\
  naději #c[D7]máš vždycky #c[G]dítě, a #c[D]to snad #c[A]můžeš #c[D]znát.
]

#chorus[
  Nadějí láskou a vírou...
]

#verse[
  Dnes tvejm krokům kámen brání, píseň tvá však nemá stání.\
  Dnes tvejm krokům kámen brání, pojď na cestu se dát.
]

#chorus[
  Nadějí láskou a vírou...
]

#verse[
  Vím, že láska neumírá, tomu, kdo ji neodpírá.\
  Vím, že láska neumírá, tak neboj se mít rád.
]

#chorus[
  Nadějí láskou a vírou...
]

#verse[
  Kdo má cíl a kdo je v právu, kdo má víru a nechce slávu.\
  Kdo má cíl a kdo je v právu, ten může s námi hrát.
]

#chorus[
  Nadějí láskou a vírou...
]

#verse[
  Osud těm, kdo v pravdu věří, rukou spravedlivou měří.\
  Jenom ten, kdo v pravdu věří, ten může klidně spát.
]

#chorus[
  Nadějí láskou a vírou...
]

