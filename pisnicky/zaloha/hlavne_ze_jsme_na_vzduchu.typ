#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Hlavně, že jsme na vzduchu],
  author: [Zdeněk Svěrák a Jaroslav Uhlíř],
  doc,
)

#verse[
  #c[C]Když radosti není dosti,
  #c[F]raduju se z maličkostí.\
  #c[C]Představím si #c[Ami]třeba kdyby
  #c[G]lidi žili jako ryby.
]
#chorus[
  #c[G]To je #c[C]dobře náho#c[Emi]dou,
  že ne#c[F]žijem pod vo#c[C]dou.\
  Na vzdu#c[Emi]chu, na vzdu#c[F]chu,
  můžem #c[G]zpívat ejchu#c[C]chu.\
  #c[G]Zpíva#c[C]ti si pod vo#c[Emi]dou,
  nejde #c[F]ani náho#c[C]dou.\
  Z hlubi#c[Emi]ny, z hlubi#c[F]ny,
  vyšly #c[G]by jen bubli#c[C]ny.
]
// R1
#chorus[
  To je dobře náhodou...
]
#verse[
  Jen si představ milá babi,
  že jsme dejme tomu krabi.\
  Nebyla bys mou babičkou,
  byla bys mořskou krabičkou.
]
// R2
#chorus[
  Buďme rádi Bohouši,
  že žijeme na souši.\
  Na zemi, na zemi,
  ušmudlané sazemi.\
  Vžij se rybě do kůže,
  třeba ti to pomůže.\
  I když jsi na suchu,
  hlavně že jsi na vzduchu.
]
// R2
#chorus[
  Buďme rádi Bohouši...
]

