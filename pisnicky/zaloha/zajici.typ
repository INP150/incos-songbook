#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Zajíci],
  author: [Jaromír Nohavica],
  doc,
)

// TODO: Uvozovky\
#verse[
  #c[G]Podzimní bílá mlha #c[C]válí se #c[G]na mechu,\
  #c[C]myslivci #c[D]vstali' už #c[G]ráno,\
  #c[G]zajíci zalezli a #c[C]nechce se jim #c[G]z pelechu,\
  #c[C]neboť se #c[D]chtějí dožít #c[G]Vánoc.
]

#chorus[
  #c[G]Vzduchem zní fanfára - #c[D]tramtarararara,\
  #c[C]po poli kráčejí #c[G]střelci,\
  já se svou #c[D]kytarou zpí#c[C]vám písničku #c[G]prastarou\
  #c[C]o tom, že #c[D]malí budou #c[G]velcí.\
  #c[G D C G]Na nananana...\
  já se svou #c[D]kytarou zpí#c[C]vám písničku #c[G]prastarou\
  #c[C]o tom, že #c[D]malí budou #c[G]velcí.\
]

#verse[
  Zajíci naposledy potřesou si tlapkama,\
  a potom obléknou dresy,\
  začíná specielní slalom mezi brokama,\
  na trati pole--louky--lesy.
]
#chorus[
  Vzduchem zní fanfára...
]
#verse[
  Už volá hlavní zajíc: "Pravda vítězí,\
  nohy jsou naše hlavní zbraně,\
  až to tu skončí, sraz je v sedm večer na mezi,\
  a teď, zajíci, hurá na ně!"
]
#chorus[
  Vzduchem zní fanfára...
]

