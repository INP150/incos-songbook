#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Hlupáku najdu tě],
  author: [Zdeněk Svěrák a Jaroslav Uhlíř],
  doc,
)

#verse[
#c[D]Někdo má hadry #c[G]na tě#c[D]le, někdo je nosí v #c[A7]hlavě,\
#c[D]berme ten rozdíl #c[G]vese#c[D]le, #c[A]berme ten rozdíl #c[D]hravě.\
#c[D]Nadutec hloupost #c[G]nese #c[D]si důstojně jako #c[A7]páv,\
#c[D]platí to v každé #c[G]profe#c[D]si, #c[A]švec nebo doktor #c[D]práv.
]
#chorus[
#c[D]Hlupáku, najdu tě, tváříš se #c[A7]nadutě,\
#c[D]když #c[D7]lezeš #c[G]na kutě, #c[A7]když ráno #c[D]vstáváš.\
#c[D]Ať jedeš v kočáře a nebo #c[A7]na káře,\
#c[D]můj #c[D7]pyšný #c[G]hlupáku, #c[A7]tebe já #c[D]znám.
]
#verse[
Sotva byl váš svět stvořený, sotva byl váš svět stvořen,\
pustila hloupost kořeny, pustila hloupost kořen.\
Rodina zdravých mamlasů valí se jako proud,\
jde s námi z časů do časů, dá se s tím vůbec hnout?
]
#chorus[
Hlupáku, najdu tě...
]

