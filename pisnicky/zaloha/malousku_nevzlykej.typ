#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Maloušku nevzlykej (2022)],
  doc,
)

#verse[
  #c[Ami]Maloušku nevzlykej, to nejsou #c[C]kopřivy,\
  #c[G]zítra si spočineš, půjdeme #c[E7]do Přiby,\
  #c[F]snad už to skončíme támhle v Železných Hor#c[E]kách.
]

#verse[
  Napij se po doušku, vodu nech pro sebe,\
  drž se mě, maloušku, bojím se o tebe,\
  maloušku v rozbitých rozvázaných pohorkách.
]

#chorus[
  #c[Ami Emi Ami Emi...]Prší a venku se setmělo,\
  tato noc nebude krátká,\
  #c[Ami]oddílák #c[F]klepe si #c[Ami]na čelo,\
  #c[F]asi to... #c[Ami]nebyla #c[E]zkratka?
]

#verse[
  Maloušku, pospěš si, k Tvrzi se blížíme,\
  u šifry sedneš si, chvilku se zdržíme,\
  Půjdeme po značce, tam nezakufrujeme.
]

#verse[
  Nad mlýnem se šeří, jídlo nám dochází,\
  všichni už večeří, my jdeme do mlází,\
  značku jsme nenašli, zpátky už nemůžeme.
]

#chorus[
  Prší a venku se setmělo...
]

