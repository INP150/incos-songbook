#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Když jsem já sloužil],
  author: [Česká lidová],
  doc,
)

#verse[
  #c[D]Když jsem já sloužil #c[A]to první léto,\
  #c[A]vysloužil jsem si #c[D]kuřát#c[A]ko za #c[D]to.\
  #c[D]A to kuře krákoře #c[A]běhá po dvoře,\
  #c[A]má panenka pláče #c[D]doma #c[A]v komo#c[D]ře.
]

#verse[
  ... kachničku ...\
  A ta kačka blátotlačka, ...\
  _(kuře)_
]

#verse[
  ... husičku ...\
  A ta husa chodí bosa, ...\
  _(kačka, kuře)_
]

#verse[
  ... vepříka ...\
  A ten vepř jako pepř, ...\
  _(husa, kačka, kuře)_
]

#verse[
  ... telátko ...\
  A to tele hubou mele, ...\
  _(vepř, husa, kačka, kuře)_
]

#verse[
  ... kravičku ...\
  A ta kráva mléko dává, ...\
  _(tele, vepř, husa, kačka, kuře)_
]

#verse[
  ... volečka ...\
  A ten vůl jako kůl, ...\
  _(kráva, tele, vepř, husa, kačka, kuře)_
]

#verse[
  ... botičky ...\
  A ty boty do roboty, ...\
  _(vůl, kráva, tele, vepř, husa, kačka, kuře)_
]

#verse[
  ... panenku ...\
  To děvčátko jak poupátko, ...\
  _(boty, vůl, kráva, tele, vepř, husa, kačka, kuře)_\
  má panenka skáče se mnou v komoře.
]

