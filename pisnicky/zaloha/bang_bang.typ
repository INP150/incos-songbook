#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Bang Bang (2013)],
  doc,
)

#set text(size: 0.9em)

#chorus[
  #c[Fmi]Zhaslo slunce už je noc,\
  #c[Fmi]událo se toho moc,\
  #c[Hmi]víčka každý zavírá,\
  #c[C]u ohně tábor usíná
]

#grid(
  columns: 2,
  row-gutter: 2em,
  [
    #verse[
      Bang Bang, tak už jděte spát,\
      BB, před tím se vyčůrat,\
      BB, nemočit za stany,\
      BB, to budem naštvaný.\
      BB, Ema po Teddym kouká,\
      BB, hned do stanu se mu souká,\
      BB, Sáva má kroksu a holínku,\
      BB, v cíli je za chvilinku.
    ]
    #chorus[
      Zhaslo slunce...
    ]
  ],
  [
    #verse[
      BB, Jája hlasivky už nemá,\
      BB, pořád křičí jen: "červená, červená",\
      BB, Anežka má tři kolena,\
      BB, huláká na tým: "vy polena!"\
      BB, náš Honzík nugetka,\
      BB, něžný jako baletka,\
      BB, a ta crazy Tereza,\
      BB, nervy má ze železa.
    ]
    #chorus[
      Zhaslo slunce...
    ]
  ],

  [
    #verse[
      BB, Ondru bolí paleček,\
      BB, líbí se mu Stromeček,\
      BB, Stromeček se smíchem otřásá,\
      BB, pyžamo do holin vykasá,\
      BB, Žabky jsou vždy veselé,\
      BB, netváří se kysele,\
      BB, Majda Bé je praštěná,\
      BB, ČaČuou je školená.
    ]
    #chorus[
      Zhaslo slunce...
    ]
  ],
  [
    #verse[
      BB, šátek cípem dopředu,\
      BB, David s rádiem je v dohledu,\
      BB, Kiszovic holky se nezdají,\
      BB, hlavy kolem nich padaí,\
      BB, tak už jděte spát,\
      BB, před tím se vyčůrat,\
      BB, krásné sny vám přejem,\
      BB, zítra si zas zapějem.
    ]
  ],
)

