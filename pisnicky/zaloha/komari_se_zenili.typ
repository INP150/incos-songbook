#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Komáři se ženili],
  author: [Slezská lidová],
  doc,
)

#verse[
  #c[D]Koma#c[A7]ři se #c[D]ženili, #c[A7]bzum, bzum, #c[D]ženili,\
  #c[D]kapky #c[A7]vina #c[D]neměli, #c[A7]bzum, bzum, #c[D]něměli.\
  #rep[
    #c[D]Koma#c[G]ři se ženili, ženili,\
    #c[A7]kapky vina #c[D]ně#c[A7]mě#c[D]li.
  ]
]

#verse[
  Přiletěl k nim slaviček, bzum, bzum, slavíček,\
  přines vina zidliček, bzum, bzum, zidliček.\
  #rep[
    Komaři se opili, opili,\
    až komara zabili.
  ]
]

#verse[
  Komár leži v komoře, bzum, bzum, v komoře,\
  muškap plače na dvoře, bzum, bzum, na dvoře.\
  #rep[
    Něplač, muško, co ti je, co ti je,\
    vždyť ti komar ožije.
  ]
]

#verse[
  Těžke jeho ožiti, bzum, bzum, ožiti,\
  když je na smrť zabity, bzum, bzum, zabity.\
  #rep[
    Sadlo z něho vybrali, vybrali,\
    za pět zlatych prodali.
  ]
]

