#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Carpe diem],
  author: [AG Flek],
  doc,
)

#verse[
  #c[Ami]Nadešel asi #c[Dmi7]poslední den, podí#c[G]vej, celá planeta #c[Emi]blázní,\
  a já #c[Ami]neuroním ani #c[Dmi7]slzu pro ni, jenom #c[G]zamknu dům.#c[E]\
  Půjdu #c[Ami]po kolejích až #c[Dmi7]na konečnou,\
  hle, jak #c[G]mám krok vojensky #c[Emi]rázný\
  a #c[Ami]nezastavím ani #c[Dmi7]na červenou, natruc #c[G]předpisům.
]

#chorus[
  #c[Ami]Tak tady mě #c[G]máš, #c[Ami]dnes můžeš #c[G]říkat klidně, co #c[C]chceš,\
  zbylo tak #c[C]málo vět, tak #c[Ami]málo slov, co #c[G]nelžou.
]

#verse[
  Už si nebudeme hrát na román, setři růž, nikdo nás nenatáčí,\
  je poslední den a zbyla nám jen miska cukroví.\
  Ať všechny hospody dnes doženou plán,\
  ať svět z posledního pije a tančí,\
  já nebudu pít, nechám naplno znít v hlavě všechno, co mám.
]

#verse[
  Žádný slib z těch, co jsem ti dal,\
  nejde vyplnit a nejde vzít zpátky.\
  Tak ať točí se svět mladší o deset let na desce Jethro Tull.\
  Ať platí aspoň dnes, co dřív jsem jen lhal,\
  carpe diem, život je krátký,\
  v tvých očích je klid a nemám chuť snít, co by bylo dál.
]

#chorus[
  #c[Ami]Tak tady mě #c[G]máš, #c[Ami]dnes můžeš #c[G]říkat klidně, co #c[C]chceš,\
  zbylo tak #c[C]málo vět, tak #c[Ami]málo slov.
]

