#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Ztrácíš se],
  author: [Marek Ztracený],
  line_spacing: 0.5em,
  font_size: 0.9em,
  cols: 2,
  doc,
)

#verse[
  #c[G]Někdy lidem #c[Ami]zbyde jenom víra,\
  #c[Hmi]co se ztrácí #c[Ami]při pohledu na svět.\
  #c[G]A milovaný lidi #c[Ami]mizej v černých dírách\
  #c[Hmi]a někdo doufá, #c[Ami]že se potkaj cestou nazpět.\
  #c[D]A když ostatní jenom #c[C]přihlížej\
  #c[D]na smutný oči, který #c[C]vyhlížej...
]

#verse[
  A některý věci nejsou v lidský moci,\
  hrdě opětuju tvoje mlčení.\
  I když jsem sám, jsem s tebou ve dne v noci\
  a tiše doufám ve vysvobození.\
  A když ostatní jenom přihlížej a ty sníš...\
  čas pluje dál, doufám, že víš...
]

#chorus[
  #c[G]Ztrácíš se z #c[F]mojí paměti\
  a lidi #c[C]od nepaměti se znovu #c[G]scházej... jée\
  A #c[G]doufám, že #c[F]stihnem těch pár vět,\
  že #c[C]najdem cestu zpět, tvý oči mi #c[G]scházej... jéjéééééé
]

#verse[
  A někdy všichni žijem jenom vírou,\
  to když nám život mizí mezi prsty.\
  Jsme jak hnutý stromy pod života tíhou,\
  všichni tušíme kam míří naše cesty.\
  A když ostatní jenom přihlížej a ty sníš,\
  čas pluje dál, doufám, že víš... jé
]

#chorus[
  Ztrácíš se z mojí paměti...
]

#colbreak()

#verse[
  #c[F]Já přece vím, že jsem ten, co chybuje, a marně #c[G]doufá...\
  #c[F]Já přece vím, že jsem ten, co chybuje,\
  a ke dnu #c[G]stoupá, ke dnu stoupá...
]

#verse[
  #c[Ami]Stoupám ze dna vzhůru,\
  #c[E]vzhůru vodou pluju.\
  #c[C]Svůj pocit tiše křičím,\
  #c[D]že jsi pro mě vším a ničím.
]

#verse[
  #c[Ami]Stoupám ze dna vzhůru,\
  #c[E]opouštím tvoje vody.\
  #c[G]Bortím tvý hráze, stoupám,\
  #c[D]v lepší život doufám.... #c[G]jéé
]

#chorus[
  Ztrácíš se z mojí paměti...
]

#chorus[
  Ztrácíš se z mojí paměti...
]

