#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Pět ježibab],
  author: [Petr Skoumal],
  doc,
)

#verse[
  #c[Dmi]Pět ježibab #c[A]s jedním o#c[Dmi]kem\
  #c[Dmi]letí, letí #c[A]nad poto#c[Dmi]kem,\
  #c[F]letí jako #c[C]hejno ptá#c[F]ků,\
  #c[Dmi]pět ježibab #c[A]na smetá#c[Dmi]ku.
]

#verse[
  Pět ježibab s jedním uchem\
  jako hejno letí vzduchem,\
  letí, letí v letu svačí\
  pět ježibab na tryskáči.
]

#verse[
  Pět ježibab s jedním nosem\
  volá na mě: "Arnošt, pojď sem!"\
  A když nejdu, tak se štětí,\
  pět ježibab na koštěti.
]
