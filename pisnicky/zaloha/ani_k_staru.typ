#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Ani k stáru],
  author: [Zdeněk Svěrák a Jaroslav Uhlíř],
  doc,
)

#solo[C]

#verse[
  Mám ploché #c[C]nohy po tetě a fanta#c[F]zii po svém strýci,\
  už dlouho #c[Ami]šlapu po světě a nevím, #c[G]co mám o něm říci.\
  Kdysi jsem #c[C]sníval o Nilu a pak se #c[F]plavil po Vltavě,\
  já věřil #c[Ami]spoustě omylů a dodnes #c[G]nemám jasno v hlavě,\
  nemám jasno #c[C]v hlavě.
]

#chorus[
  Ani #c[C]k stáru, ani k stáru, ani k stáru,\
  nemám #c[Gmi]o životě páru, nemám páru,\
  #c[F]třebaže jsem #c[Emi]dosti sečtě#c[C]lý, sečtě#c[G]lý.\
  Až mi #c[C]tváře zcela zblednou, zcela zblednou,\
  dal bych #c[Gmi]si ho ještě jednou, ještě jednou,\
  třeba #c[F]s Vámi, třeba #c[Emi]s Vámi, chcete-#c[C C7]li,\
  třeba #c[F]s Vámi, třeba #c[Emi]s Vámi, chcete-#c[C]li.
]

#verse[
  Už dlouho šlapu po světě a čekám, co se ještě stane,\
  mám pořád duši dítěte a říkají mi starý pane.\
  Já citově jsem založen, při smutných filmech slzy roním\
  a měl jsem taky málo žen, teď už to asi nedohoním,\
  už to nedohoním.
]

#chorus[
  Ani k stáru...

  ...

  třeba #c[F]s Vámi, třeba #c[Emi]s Vámi, chcete-#c[C C7]li,\
  třeba #c[F]s Vámi, milé #c[Emi]dámy, chcete-#c[C]li.
]
