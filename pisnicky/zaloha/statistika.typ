#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Statistika],
  author: [Zdeněk Svěrák a Jaroslav Uhlíř],
  doc,
)

#verse[
  Je #c[C]statisticky doká#c[Ami]záno, že #c[C]slunce vyjde každé #c[Ami]ráno\
  a #c[C]i když je tma jako #c[Ami]v ranci, noc #c[C]nemá celkem žádnou #c[Ami]šanci.
]
#chorus[
  #rep[
    Statis#c[F]tika nuda #c[G]je, má však #c[E7]cenné úda#c[Ami]je,\
    nekle#c[F]sejte na mys#c[G]li, ona #c[F]nám to vyčís#c[C]lí.
  ]
]
#verse[
  Když drak si z nosu síru pouští a Honza na něj číhá v houští,\
  pak statistika předpovídá, že nestvůra už neposnídá.
]
#chorus[
  Statistika...
]
#verse[
  Tak vyřiďte to ctěné sani, že záleží to čistě na ní,\
  když nepustí ji choutky dračí, tak bude o hlavičku kratší.
]
#chorus[
  Statistika...
]

