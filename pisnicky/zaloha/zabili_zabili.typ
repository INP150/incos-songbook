#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Zabili, zabili],
  author: [Iva Bittová, Miroslav Donutil a Zuzana Lapčíková],
  doc,
)

#verse[
  #c[D]Zabili, #c[G]zabili #c[Emi]chlapa z Kolo#c[G]čavy,#c[D][~]~\
  #c[D]řekněte #c[G]hrobaři, #c[Emi]kde je pocho#c[G]vaný.#c[D]
]
#chorus[
  #c[D]Bylo tu, není tu, havrani #c[G]na plotu,\
  #c[D]bylo víno v sudě, teď tam voda #c[A]bude,\
  #c[D]není, #c[A]není #c[D]tu.
]
#verse[
  Špatně ho zabili, špatně pochovali,\
  vlci ho pojedli, ptáci rozklovali.
]
#chorus[
  Bylo tu, není tu...
]
#verse[
  Vítr ho roznesl po dalekém kraji,\
  havrani pro něho po poli krákají.
]
#chorus[
  Bylo tu, není tu...
]
#verse[
  Kráká starý havran, krákat nepřestane,\
  dokud v Koločavě živý chlap zůstane.
]

