#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Dokud se zpívá],
  author: [Jaromír Nohavica],
  doc,
)

#verse[
  #c[C]Z Těšína #c[Emi]vyjíždí #c[Dmi7]vlaky co #c[F]čtvrthodi#c[C]nu,
  #c[Emi Dmi7 G]\
  #c[C]včera jsem #c[Emi]nespal a #c[Dmi7]ani dnes #c[F]nespoči#c[C]nu,
  #c[Emi Dmi7 G]\
  #c[F]svatý Me#c[G]dard, můj pa#c[C]tron, ťuká si na če#c[Ami]lo, #s[G]\
  ale #c[F]dokud se #c[G]zpívá, #c[F]ještě se #c[G]neumře#c[C]lo,
  #c[Emi]#s[Dmi7]hó#s[G]hó.
]

#verse[
  Ve stánku koupím si housku a slané tyčky,\
  srdce mám pro lásku a hlavu pro písničky,\
  ze školy dobře vím, co by se dělat mělo,\
  ale dokud se zpívá, ještě se neumřelo, hóhó.
]

#verse[
  Do alba jízdenek lepím si další jednu,\
  vyjel jsem před chvílí, konec je v nedohlednu,\
  za oknem míhá se život jak leporelo,\
  ale dokud se zpívá, ještě se neumřelo, hóhó.
]

#verse[
  Stokrát jsem prohloupil a stokrát platil draze,\
  houpe to, houpe to na housenkové dráze,\
  i kdyby supi se slítali na mé tělo,\
  tak dokud se zpívá, ještě se neumřelo, hóhó.
]

#verse[
  Z Těšína vyjíždí vlaky až na kraj světa,\
  zvedl jsem telefon a ptám se: "Lidi, jste tam?"\
  z veliké dálky do uší mi zaznělo,\
  že dokud se zpívá, ještě se neumřelo, hóhó\
  že dokud se zpívá ještě se neumřelo.
]

