#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Fajn džob],
  author: [Hop Trop],
  doc,
)

#verse[
  "Moje #c[Dmi]briga má #c[C]jméno #c[Dmi]Ariel", řekl #c[Dmi]kapitán, #c[C]když mě #c[Dmi]zval.\
  #rep[#c[F]Prej, abych s ním jako #c[C]lodník jel a #c[Dmi]džob, co mi #c[C]nabíd, #c[Dmi]bral.]
]

#verse[
  Von veliký prachy mi sliboval, čert ví, jestli ňáký má.\
  #rep[Já nevěřil, a tak žvanil dál, že zejtra už vyplouvá.]
]

#chorus[
  #c[D]Celej den a #c[G]celou #c[D]noc,
  #c[Hmi]stožár se pode mnou #c[A7~~]kej#w[D]vá\
  #c[D]chceš to znát, #c[G]klidně #c[D]pojď,
  // TODO: Nevím proč se to tady neodsazuje -.-
  ať #c[Hmi]víš taky, jaký to #c[A7][bej] - #c[D]vá.\
  #c[D]Žaludek stoupá #c[G]vejš a #c[D]vejš,
  #c[Hmi]na lodi všechno #c[A7]skří#w[D]pá,\
  #c[D]do vočí, tak jako #c[G]mořská #c[D]sůl,
  #c[Hmi]vostrej vítr mi #c[A7~]ští#w[D]pá.
]

#verse[
  Kdyby do vočí někdo vám tvrdil, že by práci pro vás měl fajn.\
  #rep[Dejte si říct, to by bral jenom ten, kdo je blázen a nemá šajn.]
]

#chorus[
  Celej den a celou noc, stožár se pode mnou kejvá...
]
