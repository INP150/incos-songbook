#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Půlnoční],
  author: [Václav Neckář],
  doc,
)

#verse[
  #c[D]Jedu domů po trati, jedu přes ko#c[G A][pce.]~\
  #c[D]Za okny padá, padá sníh, budou Váno#c[G A][ce.]~\
  #c[D]Chmury, trable, starosti, nechal jsem ve mě#c[G A][stě.]~\
  #c[D]Už slyším lidi na půlnoční zpívat v koste#c[G A]le.
]

#bridge[
  Hale#c[D]luja, Hale#c[Hmi]lu-u-u-u-u-#c[G]ja
]

#verse[
  Ježíš na kříži ztrápený, občas se usměje.\
  Na ty co v zázrak uvěří, na ty co zpívají.
]

#bridge[
  Haleluja, Halelu-u-u-u-u-ja\
  Haleluja, Halelu-u-u-u-u-ja
]

#chorus[
  Beránku #c[D A]náš na nebe#c[Hmi G]sích\
  Stůj při #c[D A]nás, až přijde #c[C2]tma
]

#bridge[
  Haleluja, Halelu-u-u-u-u-ja
]

#verse[
  Stojím v prázdném kostele, hvězdy nade mnou.\
  Z kříže zbyl jenom stín, ale přesto slyším.
]

#bridge[
  Haleluja, halelu-u-u-u-u-ja\
  Haleluja, halelu-u-u-u-u-ja
]

#chorus[
  Beránku náš na nebesích,\
  stůj při nás, až přijde tma.\
  Beránku náš na nebesích,\
  neopouštěj nás, až začnem se bá-á-át, bá-á-át.
]

#bridge[
  Haleluja, Halelu-u-u-u-u-ja\
  Haleluja, Halelu-u-u-u-u-ja. Haleluja\
  Halelu-u-u-u-u-ja, Haleluja, Halelu-u-u-u-u-ja, Haleluja
]

