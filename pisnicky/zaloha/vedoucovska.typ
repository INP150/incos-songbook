#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Vedoucovská (2014)],
  doc,
)

#verse[
  #c[D]Spinkat šly už všechny #c[A]dětičky,\
  rychle je #c[C]uložit a zhasnout #c[G]lampičky,\
  #c[D]dáme jen pár krátkých #c[A]písniček,\
  pak do #c[C]kapitaná#c[A]tu.
]

#verse[
  Čeká nás zas další porada,\
  co bude zítra a co další etapa,\
  tak hurá do toho a půl je hotovo,\
  dřív než vstanou, rošťáci.
]

#chorus[
  Buzolu #c[A]neznají a s mapou #c[G]neumí,\
  v šifrách se #c[A]ztrácejí, furt někde #c[G]kufrují,\
  tak #c[A]konečně už #c[E]šly ty děti #c[D]spát.
]

#verse[
  Noční hlídka kolem prochází,\
  a nás debatujíc u stolu nachází,\
  a tak je pošlem spát ať zase můžem psát,\
  šifry na zítřejší den.
]

#verse[
  Kdyby alespoň jenom tušili,\
  že v noci nespíme a kdyby věděli,\
  co za tím práce je, berem to vesele,\
  vždyť přeci rádi máme je.
]

#chorus[
  Zuby si nečistí a ruce nemyjí,\
  jídlo jim nechutná, ešusy ztrácejí,\
  tak konečně už šly ty děti spát.

  Však #c[G]přes noc dobijí #c[D]baterky...\
  #rep[a #c[A]zítra zase #c[E]budou řádit #c[D]dál]#c[(A)]
]

