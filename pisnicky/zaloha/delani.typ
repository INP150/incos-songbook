#verse[
  #c[G]Když máš srdce zjihlé, #c[C]když máš potíže\
  #c[G]Tak dej cihlu k cihle, #c[C]těsto do díže\
  #c[Ami]Upeč #c[D7]třeba chleba, #c[G]postav třeba zeď\
  #c[C]Žal se #c[D7]krásně vstřebá, #c[G]začni #c[G7]s tím hned teď\
