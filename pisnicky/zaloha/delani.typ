]

#chorus[
  #c[C]Dělání, #c[D7]dělání #c[G]všechny smutky #c[C]zahání,\
  #c[Ami]dělání, #c[D7]dělání je #c[G]lék.#c[G7][~]~\
  #c[C]Dělání, #c[D7]dělání #c[G]to nám úsměv #c[C]zachrání,\
  #c[Ami]dělání, #c[D7]dělání je #c[G]lék.
]

