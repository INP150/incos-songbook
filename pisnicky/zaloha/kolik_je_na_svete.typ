#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Kolik je na světě],
  author: [Petr Skoumal],
  doc,
)

#verse[
  #c[D]Kolik je na světě #c[Hmi (A)]očí\
  #c[D]kolik je na světě #c[Emi]snů\
  #c[Emi]kolik se koleček #c[F\#mi]točí\
  #c[G]kolik je nocí a #c[A]dnů.
]

#verse[
  Kolik je na světě moří\
  kolik je na světě řek\
  kolik je smutků a hoří\
  kolik je rozlitých mlék.
]

#chorus[
  #c[D]Toho i toho je #c[A]mnoho\
  #c[C]lidí a věcí a #c[G]jmen\
  #c[D]jediné slunce je #c[A]jedno\
  #c[A]a to když #c[Hmi]vyjde #c[G]je den.
]

#verse[
  Kolik je na světě poupat\
  kolik je na světě knih\
  kolik je jezevčích doupat\
  kolik je jezevců v nich.
]

#verse[
  Kolik je na světě školek\
  kolik je na světě škol\
  kolik je kluků a holek\
  kolik je šlapacích kol.
]

#chorus[
  Toho i toho je mnoho\
  toho i toho je moc\
  jediné slunce je jedno\
  a to když zajde je noc.
]

