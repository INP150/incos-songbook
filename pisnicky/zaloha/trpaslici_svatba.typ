#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Trpasličí svatba],
  author: [Zdeněk Svěrák a Jaroslav Uhlíř],
  doc,
)

#verse[
  #c[C]V lese, jó v lese #c[F]na jehli#c[C]čí,\
  koná se svatba #c[D]trpasli#c[G]čí,\
  #c[C]žádná divná #c[F]věc to ne#c[E]ní,\
  #c[F]Šmudla už má #c[C]po vojně a #c[F]tak se #c[G]že#c[C]ní.
]

#verse[
  Malou má ženu, malinkatou,\
  s malým věnem, malou chatou.\
  Už jim choděj' telegrámky,\
  už jim hrajou Mendelssohna na varhánky.
]

#chorus[
  Protože #c[G]láska, láska, láska v každém #c[C]srdci klí#c[G]čí,\
  protože #c[G]láskou hoří i to srdce #c[C]trpasli#c[G]čí\
  a kdo se #c[G]v téhle věci jednoduše #c[C]neopi#c[G]čí,\
  ten ať se #c[G]dívá, co se děje v lese #c[C]na jehli#c[G]čí.
]

#verse[
  Mají tam lásku, jako trámek,\
  pláče tchýňka, pláče tchánek,\
  štěstíčko přejou mladí, staří,\
  v papinově hrníčku se maso vaří.
]

#verse[
  Pijou tam pivo popovický,\
  Šmudla se polil, jako vždycky,\
  Kejchal kejchá na Profouse,\
  jedí hrášek s uzeným a nafouknou se.
]

#chorus[
  Protože láska...
]

#verse[
  \= 1.
]

