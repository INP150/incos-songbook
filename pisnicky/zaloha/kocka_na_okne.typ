#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Kočka na okně],
  author: [Jiří Suchý, Jiří Šlitr],
  doc,
)

#verse[
  #c[C]La-la-la-#c[C\#dim]lá-la-la, #c[G]la-la-la-#c[E7]lá-la-la, #c[Ami]la-la-#c[D7]la-la-lá-#c[G]la.\
  Na #c[G]okně seděla kočka, byl horký letní den,\
  na okně seděla kočka a #c[D7]koukala se ven,\
  byl horký  letní den a kdekdo chodil bos,\
  na okně seděla kočka, venku #c[G]zpí#c[G\#dim]val #s[D7]kos.

  Byl #c[G]horký letní den a celý #c[Hmi]svět se #c[E]smál\
  a #c[Ami]mně veselý sen se pod ja#c[D7]bloní zdál,\
  a #c[G]celý svět se smál, vi#c[E7]dím to jako dnes,\
  na #c[Ami]okně #c[E]seděla #c[Ami]kočka a #c[D7]venku štěkal #c[G]pes.
]
