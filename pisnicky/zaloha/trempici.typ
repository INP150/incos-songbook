#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Trempíci],
  author: [],
  doc,
)

#verse[
  #c[C]Silnicí ženou dva #c[Ami]trampíci,\
  v podpaží #c[G7]slepici ukrade#c[C]nou.\
  #c[C]Za nima běží dva #c[Ami]četníci,\
  a starosta #c[G7]s pravicí napřaže#c[C]nou.
]
#chorus[
  Jó, tihle #c[F]trempi - to je #c[C]chasa,\
  lesem se #c[D7]šíří vůně #c[G7]masa - masa pečenýho.\
  #c[C]K večeři žerou jak #c[Ami]žoldnéři,\
  slepici #c[G7]i s peřím ukrade#c[C]nou.
]
#verse[
  V Nevadě na dálném Západě,\
  sešli se k poradě indiáni.\
  Náčelník vyklepal popelník,\
  nacpal si kalumet a zabafal.
]
#chorus[
  Jó, tihle trampi...
]

