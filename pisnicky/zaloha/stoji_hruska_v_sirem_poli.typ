#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Stojí hruška v širém poli],
  author: [Čechomor],
  doc,
)

#verse[
  Sto#c[D]jí hruška v ši#c[A]rém poli\
  vr#c[D]šek se jí #c[G]zele#c[A]ná\
  #rep[
    Pod #c[D]ní se #c[G]pase #c[A]kůň vra#c[Hmi]ný\
    pa#c[D]se ho #c[A]má mi#c[D]lá
  ]
]

#verse[
  Proč má milá dnes pasete\
  z večera do rána\
  #rep[
    Kam můj milý pojedete\
    já pojedu s váma
  ]
]

#verse[
  Já pojedu daleko\
  přes vody hluboké\
  #rep[
    Kéž bych byl nikdy nepoznal\
    panny černooké
  ]
]

