#verse[
  #c[A]Není nutno, není nutno, aby bylo přímo vese#c[Hmi][lo,]~\
  #c[E7]hlavně nesmí býti smutno, natož aby se breče#c[A]lo.#c[E]
]

#verse[
  Chceš-li, trap se, že ti v kapse zlaté mince nechřestí,\
  nemít žádné kamarády, tomu já říkám neštěstí.
]

#chorus[
  Nemít #c[F\#mi]prachy - #c[A]nevadí, nemít #c[F\#mi]srdce - #c[A]vadí,\
  zažít #c[F\#mi]krachy - #c[A]nevadí, zažít #c[F\#mi]nudu - #c[D]jó, to #c[E]vadí.#c[E7]
]

