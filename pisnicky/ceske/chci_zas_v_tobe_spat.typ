#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Chci zas v tobě spát],
  author: [Lucie],
  capo: 1,
  line_spacing: 0.5em,
  font_size: 0.90em,
  doc,
)

#solo[
  #rep[F Fmaj7 Dmi B]
]

#verse[
  #c[F]Mlčíš a svět je funny, #c[Fmaj7]záhadou,
  #c[Dmi]stává se pro mě honey, když #c[B]dračí drápy tnou.\
  #c[F]Temnice tmavá vříská, #c[Fmaj7]bleskne tmou,
  #c[Dmi]mý vlasy loučí, víská a #c[B]letí nad vodou.\
  #c[C]A hrubý síly vzývám, #c[B]snídám bezprá#c[F]ví,\
  #c[C]tvý oči v hlavě vídám, #c[Gmi]je to všechno jedna velká síla.
]


#chorus[
  #c[Dmi]Jestli se vážně hodíš, #c[B]nevím nejdu spát,
  #c[C]na kolej kluky vodíš a #c[B]ráno se chceš brát.\
  #c[Dmi]Jestli se ke mně hodíš, #c[B]snad jdu k tobě spát,
  #c[C]s láskou se vůní brodíme,\
  #c[B]postelový království, #c[C]za koně nechce se mi #c[B]dát.\
  #c[B]Jsem na tom #c[C]stejně mám tě #c[Dmi]rád.\
  #c[B]Jablkem, #c[C]jablkem nejsi,
  #c[Gmi]kousnu hloub a zlíbám tě celou.\
  #c[B]Merci, ó merci, tak opustit zoufalců #c[C]ráj,
  chci zas v tobě #c[Dmi]spát.
]


#solo[
  Dmi B Gmi B C
]

#verse[
  Říkáš, že svět je krásnej, svět je zlej,
  až naše hvězda zhasne, haudy, haudy, heéééj.\
  Štěstím se lůza brodí, naříká,
  hledá a pravdu rodí, neví, nesvlíká, se lásko.\
  A hrubý síly vzývám, snídám bezpráví,\
  tvý oči v hlavě vídám, je to všechno jedna velká síla.
]

#chorus[
  Jestli se vážně hodíš, nevím nejdu spát...
]


#solo[
  Dmi B G B
]


#bridge[
  #c[Dmi]Sami se k břehům kloníme, #c[B]sami jak bezvládnej proud,\
  #c[Gmi]sami se proti vlnám stavíme, #c[B]sami se chcem, zbavit těch pout.\
  #c[Dmi]Sami se k břehům kloníme, sami jak bezvládnej #c[B]proud, jééé\
  #c[G]sami se proti vlnám staví#c[B]me...#c[C]
]


#chorus[
  #rep[#c[B]Jsem na tom #c[C]stejně, mám Tě #c[Dmi]rád.]\
  #c[B]Jablkem, #c[C]jablkem nejsi,
  #c[Gmi]kousnu hloub a zlíbám Tě celou.\
  #c[B]Merci, ó merci, tak opustit zoufalců #c[C]ráj,
  chci zas v Tobě #c[Dmi]spát...
]
