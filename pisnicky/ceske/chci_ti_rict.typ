#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Chci ti říct],
  author: [Mig 21],
  font_size: 0.89em,
  line_spacing: 0.5em,
  doc,
)

#solo[
  #rep[Gmi7 C7 Gmi C7]
]

#verse[
  #c[Gmi7]Chladná #c[C7]rána jsou #c[Gmi7]tomu, kdo #c[C7]strádá\
  #c[Gmi7]Láskou #c[C7]bolestnou #c[Gmi7]neopětova#c[C7]nou.\
  Pokud #c[Gmi7]víš, jak #c[C7]rád tě mám #c[Gmi7]a ty mě máš #c[C7]ráda,\
  #c[Gmi7]chuť a #c[C7]vůni tvou #c[Gmi7]nejde zapome#c[C7]nout.
]

#prechorus[
  Chystá #c[Dmi]se prej #c[Dsus2]konec #s[Cadd9]světa, #s[C]tramta#c[Gmi]dá\
  #c[Dmi]mě jen #c[Dsus2]jedna #s[Cadd9]věta #s[C]napa#c[B7]dá (pojď s tim ven!)
]

#chorus[
  #c[F]Chci ti říct, že #c[C]mám tě rád, že #c[Gmi]miluju tě jako blázen\
  #c[F]Chci si nechat #c[C]tetovat jen #c[Gmi]jméno tvé, chci vypít bazén\
  #c[F]vody, kterou #c[C]plavala jsi, #c[Gmi]zasadit si tvoje vlasy,\
  #c[F]rozfoukat je #c[C]do ulic #c[Gmi]chci ti říct, že rád tě mám #c[B7]víc.
]

#verse[
  Dýcháš na mou tvář, já na tvou dýchám\
  Chvěješ se myšlenkou, že se rozední\
  Děláš jako že nespěcháš, já že nepospíchám\
  Nechce se z objetí, když je poslední
]

#prechorus[
  Chystá se prej konec světa, tramtadá...
]

#verse[
  Chci ti říct, že mám tě rád...
]

#solo[
  #rep(repeat: 4)[F C Gmi]
]

#bridge[
  #c[B7]Mít tak promyšlenej plán, předem fakt moc se omlouvám\
  ale #c[B7]ode dneška od půl jedný musíme bejt zodpovědný\
  #c[B7]Mít tak promyšlenej plán, předem fakt moc se omlouvám\
  ale #c[B7]ode dneška od půl jedný musíme bejt zodpovědný\
  #c[B7]Mít tak promyšlenej plán, ale nemám ho, nemám ho, nemám (a tak!)
]

#chorus[
  Chci ti říct, že mám tě rád...
]

#solo[
  #rep(repeat: 4)[F C Gmi]\
  F
]
