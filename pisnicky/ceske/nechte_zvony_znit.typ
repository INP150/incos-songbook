#show: doc => song(
  title: [Nechte zvony znít],
  author: [Marta Kubišová],
  doc,
)

#verse[
  #c[C]Bez tebe mám #c[G]jenom chvíli #c[C]dlouhou,\
  #c[C]naplněnou #c[G]spoustou divnejch #c[C]snů.\
  V nich #c[F]starý #c[C]kostel #c[G]modlí #c[Ami]se mou #c[G]touhou\
  #c[C]a já prosím, #c[F]nechte zvony #c[B]znít.#c[G]
]

#verse[
  Chtěla bych znát píseň hrozně dlouhou,\
  vyzpívat v ní samotu mých dnů.\
  Ty naučils mě polovinu pouhou\
  a já prosím, nechte zvony znít.
]

#chorus[
  #c[E]Jen zvony ví, co jsi mi #c[Ami]vzal,#w[Ami7]\
  #c[D]jen zvony ví, co bude #c[G]dáááá#c[Dmi]ááááá#c[G]áál.
]


#verse[
  Přijde jednou skladatel a básník,\
  který umí sto divnejch snů žít.\
  Má píseň bude růst jak křehkej krápník\
  a já prosím, nechte zvony znít,\
  a já prosím, nechte zvony znít.
]

#solo[
